.mini-link{font-family:var(--mono);font-size:.68rem;color:var(--cr);
  margin-top:10px;letter-spacing:.05em}
.section-h2{font-family:var(--display);font-size:1.45rem;font-weight:700;
  color:var(--cr2);margin:32px 0 12px;padding-bottom:8px;
  border-bottom:1px solid var(--bdr)}
.section-h3{font-family:var(--display);font-size:1.15rem;font-weight:700;
  color:var(--slate);margin:24px 0 10px}
h3.sub{font-family:var(--display);font-size:1.15rem;font-weight:700;
  color:var(--slate);margin:24px 0 10px;padding-bottom:6px;
  border-bottom:1px solid var(--light)}
.disclaimer{background:var(--gold-pale);border-left:4px solid var(--gold);
  padding:12px 16px;border-radius:var(--r);margin:18px 0;
  font-size:.83rem;color:#5A3A00}
.executive-note{background:var(--cream);border:1px solid var(--bdr);
  padding:14px 18px;border-radius:var(--r);margin:14px 0;
  font-size:.83rem;color:var(--mid);line-height:1.65}
.app-links{display:flex;gap:10px;flex-wrap:wrap;margin:14px 0}
