  'sust-metric-gifts':{t:'Metric Purpose: Green Gifts',s:'Tracks philanthropic capital tied to sustainability outcomes',b:`${statsHtml([['$184M','FY26 YTD'],['$250M','2026 target'],['74%','Progress']])}<p>Purpose: show how much donor capital is aligned to decarbonization, climate research, campus energy transition, and sustainability fellowships. This is the headline metric for the 2026 fossil-fuel-neutral milestone.</p>${mockNote()}`},
  'sust-metric-chairs':{t:'Metric Purpose: Endowed Sustainability Chairs',s:'Measures permanent faculty capacity in climate and sustainability',b:`${statsHtml([['8','FY26 YTD'],['12','Target'],['67%','Progress']])}<p>Purpose: translate campaign dollars into long-term academic capacity. Chairs are slower to close than current-use gifts, but they create durable faculty leadership and donor stewardship stories.</p>${mockNote()}`},
  'sust-metric-salata':{t:'Metric Purpose: Salata Institute Funding',s:'Tracks donor support for climate research infrastructure',b:`${statsHtml([['$71M','FY26 YTD'],['$90M','Target'],['79%','Progress']])}<p>Purpose: isolate funding that advances Harvard's cross-school climate research platform rather than campus operations alone. This helps donors see a combined research and implementation case.</p>${mockNote()}`},
