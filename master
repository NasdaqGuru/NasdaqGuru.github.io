/* -- CHART EXPAND -- */
let expC=null;
function cloneChartConfig(value,seen=new WeakMap()){
  if(value===null || typeof value!=='object') return value;
  if(typeof value==='function') return value;
  if(seen.has(value)) return seen.get(value);
  if(Array.isArray(value)){
    const arr=[];
    seen.set(value,arr);
    value.forEach((item,i)=>arr[i]=cloneChartConfig(item,seen));
    return arr;
  }
  const out={};
  seen.set(value,out);
  Object.keys(value).forEach(k=>out[k]=cloneChartConfig(value[k],seen));
  return out;
}
function syncSourceChart(srcId,attempt=0){
  if(CC[srcId]) return true;
  const canvas=document.getElementById(srcId);
  const section=canvas?.closest('.section-panel');
  if(section) initSection(section.id);
  const subPane=canvas?.closest('.sub-pane');
  if(subPane) initSubTab(subPane.id);
  if(!CC[srcId] && attempt<2){
    setTimeout(()=>syncSourceChart(srcId,attempt+1),180);
  }
  return !!CC[srcId];
}
