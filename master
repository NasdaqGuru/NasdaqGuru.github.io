<script>
(function(){
  var pathOrder=['s-opportunity','s-overview','s-transformation-outline','s-strategy','s-matrix','s-ecosystem','s-datamodels','s-automation','s-pipeline','s-roadmap','s-smarter','s-report-system'];
  var storageKey='avp_masterplan_reading_path_v2',startKey=storageKey+'_startedAt',feedbackKey=storageKey+'_feedback';
  var completedShown=sessionStorage.getItem(storageKey+'_complete')==='1',selectedFeedback='';
  function ensureStart(){try{if(!localStorage.getItem(startKey))localStorage.setItem(startKey,String(Date.now()));}catch(e){}}
  function elapsedMinutes(){ensureStart();var started=Number(localStorage.getItem(startKey)||Date.now());return Math.max(0,Math.round((Date.now()-started)/60000));}
  function timeLabel(){var m=elapsedMinutes();return m<1?'Under 1 min':(m===1?'1 min':m+' min');}
  function readState(){try{return JSON.parse(localStorage.getItem(storageKey)||'{}')||{};}catch(e){return {};}}
  function writeState(s){try{localStorage.setItem(storageKey,JSON.stringify(s));}catch(e){}}
  function currentSection(){var active=document.querySelector('.section-panel.active');return active?active.id:'s-opportunity';}
  function getTargetFrom(el){var host=el&&el.closest?el.closest('[data-target]'):null;return host?host.getAttribute('data-target'):null;}
  function openTarget(target){if(target&&typeof activateTab==='function')activateTab(target,document.querySelector('[data-tab="'+target+'"]'));}
  function updateFeedbackLink(){var note=document.getElementById('feedbackNote'),link=document.getElementById('sendFeedbackLink');if(!link)return;var s=readState(),read=pathOrder.filter(function(id){return !!s[id];}).length;var body=['Executive feedback for the UD&AS Masterplan','','Signal: '+(selectedFeedback||'Not selected'),'Reading time: '+timeLabel(),'Sections reviewed: '+read+' / '+pathOrder.length,'Current section: '+currentSection(),'','Note:',note&&note.value?note.value:''].join('\n');link.href='mailto:Khun9.Narissa@gmail.com?subject='+encodeURIComponent('Executive feedback - UD&AS Masterplan')+'&body='+encodeURIComponent(body);}
  function updateAvpTracker(){ensureStart();var s=readState(),total=pathOrder.length,read=pathOrder.filter(function(id){return !!s[id];}).length,pct=Math.round(read/total*100),spent=timeLabel();document.querySelectorAll('.avp-tracker-check').forEach(function(box){var t=getTargetFrom(box);if(t)box.checked=!!s[t];});document.querySelectorAll('.sb-path-item').forEach(function(item){item.classList.toggle('is-active',item.getAttribute('data-target')===currentSection());});var fill=document.getElementById('sbPathFill'),count=document.getElementById('sbPathCount'),pctEl=document.getElementById('sbPathPct'),time=document.getElementById('sbPathTime'),modalTime=document.getElementById('readingTimeSpent');if(fill)fill.style.width=pct+'%';if(count)count.textContent=read+' / '+total+' read';if(pctEl)pctEl.textContent=pct+'%';if(time)time.textContent='Reading time: '+spent;if(modalTime)modalTime.textContent=spent;updateFeedbackLink();if(total&&read===total&&!completedShown){completedShown=true;sessionStorage.setItem(storageKey+'_complete','1');setTimeout(function(){var modal=document.getElementById('avpCompleteModal');if(modal)modal.classList.add('open');},220);}if(read<total){completedShown=false;sessionStorage.removeItem(storageKey+'_complete');}}
  function setTargetRead(target,value){if(!target)return;ensureStart();var s=readState();s[target]=!!value;writeState(s);updateAvpTracker();}
  function resetExecutivePath(){try{localStorage.removeItem(storageKey);localStorage.removeItem(startKey);localStorage.removeItem(feedbackKey);sessionStorage.removeItem(storageKey+'_complete');}catch(e){}selectedFeedback='';completedShown=false;document.querySelectorAll('.feedback-btn').forEach(function(b){b.classList.remove('is-selected');});var note=document.getElementById('feedbackNote');if(note)note.value='';var resetCheck=document.getElementById('resetExecutivePathCheck');if(resetCheck)resetCheck.checked=false;updateAvpTracker();updateFeedbackLink();}
  window.resetExecutivePath=resetExecutivePath;
  document.addEventListener('click',function(e){var mark=e.target.closest?e.target.closest('#markCurrentRead'):null;if(mark){setTargetRead(currentSection(),true);return;}var reset=e.target.closest?e.target.closest('#resetExecutivePath,#resetExecutivePathModal,#resetExecutivePathCheck'):null;if(reset){resetExecutivePath();return;}var fb=e.target.closest?e.target.closest('.feedback-btn'):null;if(fb){selectedFeedback=fb.getAttribute('data-feedback')||'';document.querySelectorAll('.feedback-btn').forEach(function(b){b.classList.toggle('is-selected',b===fb);});try{localStorage.setItem(feedbackKey,selectedFeedback);}catch(err){}updateFeedbackLink();return;}var next=e.target.closest?e.target.closest('#nextUnreadSection'):null;if(next){var s=readState();openTarget(pathOrder.find(function(id){return !s[id];})||'s-report-system');return;}var check=e.target.closest?e.target.closest('.avp-tracker-check'):null;if(check){setTargetRead(getTargetFrom(check),check.checked);e.stopPropagation();return;}var row=e.target.closest?e.target.closest('.sb-path-item'):null;if(row)openTarget(row.getAttribute('data-target'));});
  document.addEventListener('input',function(e){if(e.target&&e.target.id==='feedbackNote')updateFeedbackLink();});
  document.addEventListener('DOMContentLoaded',function(){selectedFeedback=localStorage.getItem(feedbackKey)||'';document.querySelectorAll('.feedback-btn').forEach(function(b){b.classList.toggle('is-selected',b.getAttribute('data-feedback')===selectedFeedback);});updateAvpTracker();});
  setInterval(updateAvpTracker,60000);if(document.readyState!=='loading')updateAvpTracker();var old=window.activateTab;if(typeof old==='function'){window.activateTab=function(){var r=old.apply(this,arguments);setTimeout(updateAvpTracker,80);return r;};}
})();
</script>
