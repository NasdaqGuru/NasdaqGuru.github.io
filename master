.mbody ul{padding-left:18px;margin-bottom:12px}
.mbody ul li{font-size:.92rem;color:var(--mid);line-height:1.8}
.chart-detail{margin-top:16px;font-size:.88rem;color:var(--mid);line-height:1.7}
.chart-detail h4{font-family:var(--serif);font-size:.85rem;font-weight:700;
  text-transform:uppercase;letter-spacing:.07em;color:var(--cr);margin:12px 0 5px}
.chart-detail ul{padding-left:18px}
.chart-detail li{margin-bottom:5px}

