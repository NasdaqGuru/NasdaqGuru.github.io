    <div>
      <div class="ra-sidebar-2008" style="position:sticky;top:24px">

        <div class="ra-sb-header">
          <div class="ra-sb-eyebrow">Historical Context · Institutional Memory</div>
          <div class="ra-sb-title">Lessons from the 2008 Pause: What a Unified Data Architecture Would Have Changed</div>
        </div>

        <div class="ra-sb-body">

          <div class="ra-sb-stat">
            <div class="ra-sb-stat-item">
              <div class="ra-sb-stat-v">−26%</div>
              <div class="ra-sb-stat-l">Harvard endowment FY09</div>
            </div>
            <div class="ra-sb-stat-item">
              <div class="ra-sb-stat-v">$1.8B</div>
