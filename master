    else if(txt.includes('on track')){pct=82;tone='green';}
    else if(txt.includes('in progress')){pct=68;tone='gold';}
    else if(txt.includes('pilot')){pct=45;tone='blue';}
    else if(txt.includes('build')){pct=35;tone='gold';}
