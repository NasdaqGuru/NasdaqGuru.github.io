  'm-target':{t:'FY2026 Annual Target: $1.1B',s:'Pacing at 66.7% through Q2',b:`<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px"><div style="background:#FAE8EB;border-radius:5px;padding:13px;text-align:center"><div style="font-family:'Crimson Text',serif;font-size:1.7rem;font-weight:700;color:var(--cr)">$734M</div><div style="font-size:9px;text-transform:uppercase;color:var(--gray)">YTD</div></div><div style="background:#FDF6E3;border-radius:5px;padding:13px;text-align:center"><div style="font-family:'Crimson Text',serif;font-size:1.7rem;font-weight:700;color:var(--gold)">66.7%</div><div style="font-size:9px;text-transform:uppercase;color:var(--gray)">of Target</div></div><div style="background:#E8F5E9;border-radius:5px;padding:13px;text-align:center"><div style="font-family:'Crimson Text',serif;font-size:1.7rem;font-weight:700;color:#2E7D32">+8.2%</div><div style="font-size:9px;text-transform:uppercase;color:var(--gray)">vs FY25</div></div></div><p style="font-size:13px;color:var(--gray)">On track for $1.05–1.12B. Q4 = 33–38% of annual giving. Principal gifts (+14%), international (+18%), new donors (+14.2%) all above prior year. Note: this file uses illustrative data to demonstrate dashboard architecture.</p>`},
  'm-principal':{t:'Principal Gift Pipeline: $420M',s:'8- and 9-figure gifts in active cultivation',b:`<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px"><div style="background:#FAE8EB;border-radius:5px;padding:13px;text-align:center"><div style="font-family:'Crimson Text',serif;font-size:1.7rem;font-weight:700;color:var(--cr)">214</div><div style="font-size:9px;text-transform:uppercase;color:var(--gray)">Prospects</div></div><div style="background:#FDF6E3;border-radius:5px;padding:13px;text-align:center"><div style="font-family:'Crimson Text',serif;font-size:1.7rem;font-weight:700;color:var(--gold)">12</div><div style="font-size:9px;text-transform:uppercase;color:var(--gray)">$100M+ Prospects</div></div><div style="background:#E8EFF8;border-radius:5px;padding:13px;text-align:center"><div style="font-family:'Crimson Text',serif;font-size:1.7rem;font-weight:700;color:#1565C0">$2.8B</div><div style="font-size:9px;text-transform:uppercase;color:var(--gray)">Total Pipeline</div></div></div><p style="font-size:13px;color:var(--gray)">14% YoY growth driven by AI-powered unmanaged prospect identification, Allston campus naming opportunities, and HMS-SEAS AI Strategic Plan joint cultivation. Illustrative data demonstrating pipeline architecture.</p>`},
  'm-prospects':{t:'Managed Prospects: 4,800',s:'+620 newly identified via propensity model',b:`<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px"><div style="background:#FAE8EB;border-radius:5px;padding:13px;text-align:center"><div style="font-family:'Crimson Text',serif;font-size:1.7rem;font-weight:700;color:var(--cr)">4,800</div><div style="font-size:9px;text-transform:uppercase;color:var(--gray)">Managed</div></div><div style="background:#FDF6E3;border-radius:5px;padding:13px;text-align:center"><div style="font-family:'Crimson Text',serif;font-size:1.7rem;font-weight:700;color:var(--gold)">380</div><div style="font-size:9px;text-transform:uppercase;color:var(--gray)">Unmanaged $10M+</div></div><div style="background:#E8F5E9;border-radius:5px;padding:13px;text-align:center"><div style="font-family:'Crimson Text',serif;font-size:1.7rem;font-weight:700;color:#2E7D32">84%</div><div style="font-size:9px;text-transform:uppercase;color:var(--gray)">Model Precision</div></div></div><p style="font-size:13px;color:var(--gray)">380 unmanaged $10M+ alumni flagged. Q3 FY26 plan: assign gift officers to top 200 by propensity score. Q4: President travel to top 10 markets. FY2027: full 380 covered. Illustrative scenario data.</p>`},
  'm-pillar1':{t:'Pillar 1: Principal Gift Pipeline Intelligence',s:'5–7 year cultivation cycle · 84% AI precision',b:`<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px"><div style="background:#FAE8EB;border-radius:5px;padding:13px;text-align:center"><div style="font-family:'Crimson Text',serif;font-size:1.4rem;font-weight:700;color:var(--cr)">5–7 yr</div><div style="font-size:9px;text-transform:uppercase;color:var(--gray)">Avg Cultivation</div></div><div style="background:#FDF6E3;border-radius:5px;padding:13px;text-align:center"><div style="font-family:'Crimson Text',serif;font-size:1.4rem;font-weight:700;color:var(--gold)">3–5</div><div style="font-size:9px;text-transform:uppercase;color:var(--gray)">Meetings Pre-Ask</div></div><div style="background:#E8F5E9;border-radius:5px;padding:13px;text-align:center"><div style="font-family:'Crimson Text',serif;font-size:1.4rem;font-weight:700;color:#2E7D32">84%</div><div style="font-size:9px;text-transform:uppercase;color:var(--gray)">AI Precision</div></div></div><p style="font-size:13px;color:var(--gray)">The gradient boosting model scores every alumnus weekly on 7 factors: recency, engagement velocity, wealth signals, event attendance, email behavior, liquidity events, peer network. 84% of flagged prospects give a major gift within 18 months (illustrative scenario).</p>`},
  'm-pillar2':{t:'Pillar 2: Cross-School Data Integration',s:'9 of 12 schools live · 2.4× avg coordinated gift size',b:`<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px"><div style="background:#E8F5E9;border-radius:5px;padding:13px;text-align:center"><div style="font-family:'Crimson Text',serif;font-size:1.4rem;font-weight:700;color:#2E7D32">12</div><div style="font-size:9px;text-transform:uppercase;color:var(--gray)">Schools</div></div><div style="background:#FDF6E3;border-radius:5px;padding:13px;text-align:center"><div style="font-family:'Crimson Text',serif;font-size:1.4rem;font-weight:700;color:var(--gold)">9</div><div style="font-size:9px;text-transform:uppercase;color:var(--gray)">Live</div></div><div style="background:#FAE8EB;border-radius:5px;padding:13px;text-align:center"><div style="font-family:'Crimson Text',serif;font-size:1.4rem;font-weight:700;color:var(--cr)">2.4×</div><div style="font-size:9px;text-transform:uppercase;color:var(--gray)">Coordinated Gift</div></div></div><p style="font-size:13px;color:var(--gray)">Before federation, a donor affiliated with HBS and HMS could receive 6 separate solicitations. Illustrative scenario results: $85M AI gift (HMS+SEAS), $42M climate gift (HKS+GSD+FAS), $28M access fund (FAS+HGSE+HLS).</p>`},
  'm-pillar3':{t:'Pillar 3: Campaign Readiness Analytics',s:'3 scenarios modeled · FY2028 target launch',b:`<p style="font-size:13px;color:var(--gray)"><strong>$7B Conservative:</strong> Achievable without full international activation. Low risk.<br><strong>$10B Base Case:</strong> Requires 4–6 transformational gifts, full 12-school engagement, strong international program. Highly credible given pipeline depth.<br><strong>$12B+ Ambitious:</strong> Requires 1+ gift of $300M+, 25%+ annual fund participation, full Middle East activation.</p><p style="font-size:13px;color:var(--gray)">Feasibility study to be commissioned Q1 FY2027. Campaign readiness target pipeline: 3.5:1 coverage ratio (currently 2.5:1).</p>`},
  'm-pillar4':{t:'Pillar 4: Thematic Donor Interest Mapping',s:'Theme-matched asks close at 1.8× the rate',b:`<p style="font-size:13px;color:var(--gray)">The system reads 3 years of engagement data to infer 2–3 dominant donor themes per constituent. Top alignment scores: Financial Aid (95%), AI/Tech (88%), Public Health (80%), Climate (74%), Civil Discourse (65%).</p><p style="font-size:13px;color:var(--gray)">Donors asked for theme-aligned gifts close at 1.8× the rate of generic solicitations. This directly informs gift officer conversation strategy and the President's cultivation talking points.</p>`},
  'm-pillar5':{t:'Pillar 5: Sustainability Scorecard',s:'$94M raised · 78% to $120M target',b:`<p style="font-size:13px;color:var(--gray)">Key milestone progress: Campus Energy Transition (85%), Building Electrification (91%), Allston Net-Zero (80%), Renewable Energy Endowment (60%), Climate Research Labs (69%).</p><p style="font-size:13px;color:var(--gray)">Green gifts also serve as a gateway for non-alumni climate donors, broadening Harvard's philanthropic base. <em>Source: Harvard Sustainability Action Plan, fossil-fuel-neutral 2026 milestone (public).</em></p>`},
  'm-pillar6':{t:'Pillar 6: The Case for Flexibility',s:'$63M PPF gap remaining · flexibility propensity model active',b:`<p style="font-size:13px;color:var(--gray)">A $10M endowed professorship cannot bridge an NIH grant interruption – but a PPF gift can. The flexibility propensity model flags donors who historically give to general funds rather than named restrictions. These 380 prospects are in active PPF cultivation.</p><p style="font-size:13px;color:var(--gray)">The PPF "flexibility gap" is Harvard's most under-addressed funding risk. UD&AS is uniquely positioned to close it by surfacing and cultivating unrestricted donors across all 12 schools.</p>`},
  'm-pipeline-kpi1':{t:'214 Active Principal Prospects',s:'Across all primary schools and programs',b:`<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px"><div style="background:#FAE8EB;border-radius:5px;padding:13px;text-align:center"><div style="font-family:'Crimson Text',serif;font-size:1.7rem;font-weight:700;color:var(--cr)">38</div><div style="font-size:9px;text-transform:uppercase;color:var(--gray)">In Cultivation</div></div><div style="background:#FDF6E3;border-radius:5px;padding:13px;text-align:center"><div style="font-family:'Crimson Text',serif;font-size:1.7rem;font-weight:700;color:var(--gold)">42</div><div style="font-size:9px;text-transform:uppercase;color:var(--gray)">In Solicitation</div></div><div style="background:#E8EFF8;border-radius:5px;padding:13px;text-align:center"><div style="font-family:'Crimson Text',serif;font-size:1.7rem;font-weight:700;color:#1565C0">28</div><div style="font-size:9px;text-transform:uppercase;color:var(--gray)">In Feasibility</div></div></div><p style="font-size:13px;color:var(--gray)">71% solicitation conversion rate. 106 in stewardship – closed gifts maintained for next ask. Pipeline is healthy. All figures illustrative.</p>`},
  'm-pipeline-kpi2':{t:'$2.8B Total Pipeline Value',s:'2.5:1 coverage ratio · target 3.5:1 by FY2027',b:`<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px"><div style="background:#FAE8EB;border-radius:5px;padding:13px;text-align:center"><div style="font-family:'Crimson Text',serif;font-size:1.4rem;font-weight:700;color:var(--cr)">$1.1B</div><div style="font-size:9px;text-transform:uppercase;color:var(--gray)">HBS Pipeline</div></div><div style="background:#FDF6E3;border-radius:5px;padding:13px;text-align:center"><div style="font-family:'Crimson Text',serif;font-size:1.4rem;font-weight:700;color:var(--gold)">$840M</div><div style="font-size:9px;text-transform:uppercase;color:var(--gray)">HMS Pipeline</div></div><div style="background:#E8EFF8;border-radius:5px;padding:13px;text-align:center"><div style="font-family:'Crimson Text',serif;font-size:1.4rem;font-weight:700;color:#1565C0">$860M</div><div style="font-size:9px;text-transform:uppercase;color:var(--gray)">Other Schools</div></div></div><p style="font-size:13px;color:var(--gray)">Industry best practice for campaign readiness: 3:1 to 4:1 pipeline-to-goal ratio. Currently at 2.5:1. Reaching 3.5:1 is the FY2027 pre-campaign target. Illustrative scenario.</p>`},
  'm-pipeline-kpi3':{t:'12 Transformational Prospects ($100M+)',s:'The cornerstone gifts of the next campaign',b:`<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px"><div style="background:#E8F5E9;border-radius:5px;padding:13px;text-align:center"><div style="font-family:'Crimson Text',serif;font-size:1.7rem;font-weight:700;color:#2E7D32">4</div><div style="font-size:9px;text-transform:uppercase;color:var(--gray)">Cultivation</div></div><div style="background:#FDF6E3;border-radius:5px;padding:13px;text-align:center"><div style="font-family:'Crimson Text',serif;font-size:1.7rem;font-weight:700;color:var(--gold)">5</div><div style="font-size:9px;text-transform:uppercase;color:var(--gray)">Feasibility</div></div><div style="background:#E8EFF8;border-radius:5px;padding:13px;text-align:center"><div style="font-family:'Crimson Text',serif;font-size:1.7rem;font-weight:700;color:#1565C0">3</div><div style="font-size:9px;text-transform:uppercase;color:var(--gray)">Early Research</div></div></div><p style="font-size:13px;color:var(--gray)">In The Harvard Campaign (FY13–18), 3 gifts of $100M+ = 15% of total dollars raised. For a $10B campaign, 6–8 transformational gifts are structurally required. These 12 illustrative prospects represent that pool.</p>`},
  'inv-ai':{t:'AI/ML Talent – $1.2M',s:'3 new ML engineers in University Research',b:`<h4>Why This Investment?</h4><p style="font-size:13px;color:var(--gray)">Each 1pp of model precision improvement ≈ $4–6M additional pipeline/year. Engineers enable: (1) weekly refresh vs. nightly batch, (2) real-time wealth signals, (3) school-specific model variants (+8–12% performance). <strong>Reference:</strong> Stanford and Columbia report 25–35% principal gift conversion improvements after similar investments. Source: CASE benchmark reports.</p>`},
  'inv-vendor':{t:'Vendor Consolidation – −$340K savings',s:'3 overlapping vendors → 2',b:`<h4>Why This Investment?</h4><p style="font-size:13px;color:var(--gray)">Internal modeling now outperforms vendor-only screening by 22%. Savings reinvested in infrastructure. Competitive RFP process underway. The consolidated vendor budget funds one additional ML engineering hire.</p>`},
  'inv-crm':{t:'Affinaquest CRM Rollout – $2.8M',s:'Remaining schools · 30% velocity improvement projected',b:`<h4>Why This Investment?</h4><p style="font-size:13px;color:var(--gray)">GSD, HGSE, HLS on legacy systems. Asynchronous data = missed coordination opportunities and duplicate prospect outreach. $2.8M covers licensing, migration, training, 18 months support. <strong>Reference:</strong> Duke and Vanderbilt Affinaquest implementation case studies show 30% velocity improvement.</p>`},
  'inv-ai2':{t:'Ethical AI Audit Infrastructure – $220K',s:'Quarterly disparate-impact audits automated',b:`<h4>Why This Investment?</h4><p style="font-size:13px;color:var(--gray)">Ethical AI Charter (FY25) requires quarterly audits. Manual process = 2 weeks/quarter. Automated tooling = 48 hours + continuous monitoring. Positions Harvard ahead of emerging AI transparency regulations and donor trust expectations.</p>`},
  'inv-mobile':{t:'Mobile Gift Officer Tool – $200K',s:'+30% productive meetings per officer per year',b:`<h4>Why This Investment?</h4><p style="font-size:13px;color:var(--gray)">Gift officers currently access prospect briefs via desktop – walking into meetings without reviewing relationship data. Mobile tool surfaces: last interaction, key interests, recent wealth signals, suggested talking points. <strong>Reference:</strong> Cornell and NYU mobile GO tool pilots (CASE 2025) show 30% meeting productivity gain.</p>`},
  'risk-fed':{t:'Federal Funding Volatility',s:'HIGH likelihood · HIGH impact',b:`<h4>Context</h4><p style="font-size:13px;color:var(--gray)">NIH/NSF uncertainty directly threatens HMS and HSPH. A 10% NIH cut ≈ $180M annual research funding gap.</p><h4>Mitigation</h4><p style="font-size:13px;color:var(--gray)">Accelerate unrestricted PPF pipeline. 14 HMS prospects flagged $50M+ for emergency-bridge cultivation. PPF goal raised to $1.5B by FY28 for 24-month bridge capacity.</p>`},
  'risk-econ':{t:'Economic Headwinds',s:'MEDIUM likelihood · HIGH impact',b:`<h4>Context</h4><p style="font-size:13px;color:var(--gray)">Market correction of 20%+ reduces PE/VC prospect wealth – heavily concentrated in HBS pipeline.</p><h4>Mitigation</h4><p style="font-size:13px;color:var(--gray)">3 scenarios modeled. Recession case: 18% mid-major reduction, but principal gifts historically counter-cyclical (−4% to flat). Shift cultivation toward real-estate and planned-gift wealthy donors.</p>`},
  'risk-sentiment':{t:'Donor Sentiment',s:'MEDIUM likelihood · MEDIUM impact',b:`<h4>Context</h4><p style="font-size:13px;color:var(--gray)">Political polarization has made some donors ambivalent. However, FY13–18 data shows reputational events have minimal long-term principal gift impact (&lt;3% annual variance).</p><h4>Mitigation</h4><p style="font-size:13px;color:var(--gray)">Continuous pulse-survey of top 500 donors. Early-warning trigger if intent drops &gt;1Ïƒ. Garber-led town halls + Dean engagement.</p>`},
  'risk-privacy':{t:'AI / Privacy Reputational Risk',s:'LOW likelihood · HIGH impact',b:`<h4>Context</h4><p style="font-size:13px;color:var(--gray)">AI donor scoring is standard practice, but a data breach or "AI targeting" story could damage alumni trust.</p><h4>Mitigation</h4><p style="font-size:13px;color:var(--gray)">Ethical AI Charter · Model Cards · quarterly disparate-impact audits · human-in-loop for all 8-figure solicitations · plain-language explanation right for any constituent.</p>`},
  'risk-attrition':{t:'Gift Officer Attrition',s:'LOW likelihood · MEDIUM impact',b:`<h4>Context</h4><p style="font-size:13px;color:var(--gray)">Senior GO departure mid-cultivation sets principal gift timeline back 12–18 months.</p><h4>Mitigation</h4><p style="font-size:13px;color:var(--gray)">Competitive compensation review underway. CRM cultivation notes SLA: 48 hours. Relationship handoff protocol documented for top 50 prospects.</p>`},
  'risk-ferpa':{t:'Data Privacy / FERPA',s:'LOW likelihood · HIGH impact',b:`<h4>Context</h4><p style="font-size:13px;color:var(--gray)">FERPA restricts student record use in fundraising. EU/UK alumni have GDPR deletion rights.</p><h4>Mitigation</h4><p style="font-size:13px;color:var(--gray)">Automated regional deletion rights · annual consent refresh · annual third-party FERPA/GDPR audit · Model Cards published internally · zero cross-school data sharing without explicit opt-in.</p>`}
};

function statsHtml(items){
  return `<div class="detail-grid">${items.map(x=>`<div class="detail-tile"><strong>${x[0]}</strong><span>${x[1]}</span></div>`).join('')}</div>`;
}
function timelineHtml(items){
  return `<div class="modal-timeline">${items.map(x=>`<div class="modal-step"><strong>${x[0]}</strong><span>${x[1]}</span></div>`).join('')}</div>`;
}
function tableHtml(headers, rows){
  return `<table class="modal-table"><thead><tr>${headers.map(h=>`<th>${h}</th>`).join('')}</tr></thead><tbody>${rows.map(r=>`<tr>${r.map(c=>`<td>${c}</td>`).join('')}</tr>`).join('')}</tbody></table>`;
}
function mockNote(){
  return `<p style="font-size:12px;color:var(--gray);margin-top:10px"><em>Mock-data note: donor names, gift officer assignments, zip codes, gift amounts, and timelines are synthetic and included to demonstrate the reporting architecture.</em></p>`;
}
function monthBarsHtml(rows,max){
  return `<div class="mini-bars">${rows.map(r=>`<div class="mini-bar-row"><strong>${r[0]}</strong><div class="mini-track"><div class="mini-fill" style="width:${Math.round(r[1]/max*100)}%"></div></div><span>$${r[1]}M</span></div>`).join('')}</div>`;
}
