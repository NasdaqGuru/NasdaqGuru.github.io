  'priority-action-queue':{t:'Priority Pipeline Totals: Leadership Action Brief',s:'Top donor, prospect, school, gift officer, and decision needed',b:`${statsHtml([['$2.27B','Total priority pipeline'],['$367M','Near-term ask potential'],['6','Presidential decisions queued']])}<p>This brief is designed for a President or VP to decide where their next hour has the highest return. The recommended reading is: priority fit first, lead school second, relationship owner third, and decision needed last.</p>${tableHtml(['Priority','Lead school','Top prospect','Likely gift','Gift officer','Decision needed'],[['Presidential Priorities Fund','University-wide','Avery Stone','$75M','Maya Brooks','President-hosted small dinner in Cambridge'],['AI Strategic Plan','HMS + SEAS','Leah Kim','$60M','Jennifer Woo','President + Dean joint Bay Area meeting'],['Financial Aid Endowment','FAS','Amelia Hart','$40M','Maya Brooks','Approve scholarship naming package'],['Sustainability','GSD + FAS + SEAS','Clara Voss','$28M','Elena Foster','Pair campus electrification with research case'],['Civil Discourse','HKS + HLS + FAS','Jordan Ellison','$25M','David Chen','Quiet-phase chair concept approval'],['Global Health','HMS + HKS','Daniel Reyes','$22M','Marcus Lee','Move from program gift to platform ask']])}<h4>Decision Logic</h4><ul><li><strong>Move now:</strong> AI Strategic Plan and Presidential Priorities Fund have the strongest capacity plus timing overlap.</li><li><strong>Coordinate:</strong> Sustainability and Civil Discourse require school alignment before the President enters the conversation.</li><li><strong>Watch risk:</strong> Any priority with multiple schools needs a single relationship owner before solicitation.</li></ul>${mockNote()}`},
  'lit-hbs':{t:'Data Literacy: HBS',s:'Expert readiness · peer-champion candidate',b:literacyBrief('HBS','94% · Expert','Custom local reports may drift from shared One Harvard definitions.','Use HBS as a peer-champion school; document its best dashboard habits for other units.','HBS Ops + UD&AS','Two peer sessions delivered; shared dashboard definitions adopted by HKS/HLS/GSD.')},
  'lit-seas':{t:'Data Literacy: SEAS',s:'Expert readiness · fast-growing tech pipeline',b:literacyBrief('SEAS','91% · Expert','Fast AI/tech pipeline growth can outpace common coding and governance.','Standardize AI, climate tech, and compute-infrastructure prospect codes with HMS and FAS.','SEAS DO + Analytics','All $10M+ AI prospects share one theme taxonomy and one owner field.')},
  'lit-hms':{t:'Data Literacy: HMS',s:'Proficient readiness · complex research themes',b:literacyBrief('HMS','88% · Proficient','Research themes are complex, which can create inconsistent opportunity coding.','Create HMS-SEAS shared definitions for clinical AI, global health, and research bridge funding.','HMS DO + Research','Top 100 HMS prospects reconciled to shared presidential-priority themes.')},
  'lit-fas':{t:'Data Literacy: FAS',s:'Proficient readiness · large-team variance',b:literacyBrief('FAS','82% · Proficient','Large portfolio size creates uneven data hygiene and assignment discipline.','Run manager dashboard reviews for top 250 prospects and stale assignments.','FAS Ops + UD&AS','Stale top-prospect assignments below 5%; all top 250 have current next action.')},
  'lit-hks':{t:'Data Literacy: HKS',s:'Developing readiness · policy-theme opportunity',b:literacyBrief('HKS','71% · Developing','Policy donors may be under-coded by civil discourse, global affairs, and democracy themes.','Hold weekly office hours and recode top policy prospects against presidential priorities.','HKS DO + Strategy','Top 150 HKS prospects have updated interest tags and gift-officer next step.')},
  'lit-hls':{t:'Data Literacy: HLS',s:'Developing readiness · migration adoption risk',b:literacyBrief('HLS','65% · Developing','CRM migration can fragment relationship history and slow principal-gift briefings.','Run migration-adoption sprint focused on top principal prospects and relationship notes.','HLS Ops + CRM Team','Top 100 principal prospects have validated owner, stage, last contact, and next step.')},
  'lit-gsd':{t:'Data Literacy: GSD',s:'At-risk readiness · sustainability case opportunity',b:literacyBrief('GSD','52% · At Risk','Climate donors may not connect to central sustainability priorities without shared coding.','Assign a school data champion and build a sustainability prospect dashboard.','GSD DO + UD&AS','Top 75 climate/design prospects coded by capacity, interest, and assigned officer.')},
  'lit-hgse':{t:'Data Literacy: HGSE',s:'At-risk readiness · access/equity coordination need',b:literacyBrief('HGSE','48% · At Risk','Access and equity prospects may be missed in FAS/HLS coordination.','Run cohort training and validate the top 100 access/equity prospects.','HGSE DO + Analytics','Top 100 prospects reconciled against FAS/HLS overlaps and assigned next actions.')},
  'lit-playbook':{t:'Data Literacy Readiness Playbook',s:'90-day enablement sprint for schools below 75%',b:`${statsHtml([['Weeks 1-2','Baseline adoption and pain points'],['Weeks 3-8','Hands-on office hours and manager dashboards'],['Weeks 9-12','Leadership review and sustainment plan']])}${tableHtml(['Workstream','Action','Output'],[['Definitions','Agree on prospect stage, owner, theme, and next-action rules','One shared operating glossary'],['Dashboards','Create manager view of stale assignments and top prospects','Weekly portfolio review tool'],['Training','Run role-based training for officers, managers, and operations staff','Completion and confidence score'],['Governance','Name one school champion and one central partner','Monthly issue log and escalation path']])}${mockNote()}`},
  'lit-metrics':{t:'Data Literacy: Meaningful Metrics',s:'What to measure beyond logins',b:`${tableHtml(['Metric','Why it matters','Healthy target'],[['Active use','Shows whether gift officers actually use analytics in weekly work','90%+ monthly active users'],['Portfolio hygiene','Confirms owner, stage, last contact, and next action are current','95% of top prospects current'],['Briefing quality','Measures whether leadership gets useful donor context','100% of presidential/dean meetings briefed'],['Cross-school reconciliation','Prevents duplicate asks and missed multi-school gifts','Top shared prospects reviewed monthly'],['Model trust','Shows whether officers understand and act on scores','80%+ confidence in manager pulse check']])}<p>These metrics connect data literacy to fundraising outcomes. Login counts alone can look healthy while donor strategy remains weak.</p>${mockNote()}`},
  'lit-cadence':{t:'Data Literacy: Healthy Review Cadence',s:'How often leadership should check readiness',b:`${tableHtml(['Audience','Cadence','Focus'],[['Gift officers','Weekly','Top prospect next actions and stale portfolio items'],['School managers','Biweekly','Portfolio hygiene, training blockers, dashboard use'],['UD&AS + school ops','Monthly','Adoption, data quality, cross-school conflicts'],['VP / AVP leadership','Quarterly','Campaign-readiness risk and resource allocation']])}<p>Healthy habit: if a school is below 75% readiness, treat data literacy as an active campaign-readiness risk until three consecutive monthly reviews show improvement.</p>${mockNote()}`},

  'm-pillar2':{t:'Pillar 2: Cross-School Data Integration',s:'The Matrix Model · autonomy plus one university view',b:`${statsHtml([['2.4×','Coordinated gifts vs single-school asks'],['9 of 12','Schools live'],['Q4 FY26','Full federation target']])}<h4>Protocol</h4>${timelineHtml([['Identity','Central Donor Master links school IDs to one household view.'],['Ownership','Primary relationship owner remains visible to all schools.'],['Consent','Sensitive data follows purpose limitation and role-based access.'],['Arbitration','VP/Dean tracker resolves competing asks.']])}${tableHtml(['Example donor','Schools involved','Coordinated ask','Gift officer model'],[['Avery Stone','HMS + SEAS','$85M AI research + leadership fund','Jennifer Woo leads; HMS dean owns science case'],['Clara Voss','HKS + GSD + FAS','$42M climate and policy platform','Elena Foster leads; GSD owns design case'],['Amelia Hart','FAS + HGSE + HLS','$28M access and equity fund','Maya Brooks leads; FAS owns scholarship case']])}${mockNote()}`},
  'm-pillar4':{t:'Pillar 4: Thematic Donor Interest Mapping',s:'Top donors, gift amounts, gift officers, and ZIP-based matching',b:`${statsHtml([['1.8×','Theme-matched close-rate lift'],['436','Prospects with 2+ strong theme signals'],['ZIP + affinity','Officer assignment logic']])}${tableHtml(['Theme','Top prospect','Base / ZIP','Likely gift','Gift officer','Why matched'],[['AI / Technology','Leah Kim','Menlo Park 94025','$60M','Jennifer Woo','AI founder + HMS parent + clinical AI event attendance'],['Financial Aid','Amelia Hart','Boston 02108','$40M','Maya Brooks','Scholarship giving + reunion leadership'],['Climate','Clara Voss','Tiburon 94920','$28M','Elena Foster','ESG foundation trustee + GSD connection'],['Civil Discourse','Jordan Ellison','DC 20007','$25M','David Chen','Policy donor + HKS/HLS event pattern'],['Public Health','Daniel Reyes','San Diego 92121','$22M','Marcus Lee','Biotech liquidity + pandemic preparedness interest']])}<p>Matching logic: donor interest score + capacity + geography + school affiliation + officer portfolio fit. ZIP code helps assign gift officers who can meet in-market and coordinate presidential travel.</p>${mockNote()}`},
  'm-pillar5':{t:'Pillar 5: Sustainability Scorecard',s:'Best practices, methodology, and case study',b:`${statsHtml([['$184M','Green gifts FY26'],['74%','Progress to $250M target'],['5 tracks','Energy, buildings, Allston, endowment, labs']])}<h4>Best Practices</h4><ul><li>Separate sustainability gifts by operational outcome, not only school home.</li><li>Show donors a measurable decarbonization or research milestone.</li><li>Use blended cases: campus operations + student/faculty research + long-term endowment.</li></ul><h4>Methodology</h4>${timelineHtml([['Classify','Tag gift intent against decarbonization taxonomy.'],['Validate','Confirm restriction language and reporting metric.'],['Track','Quarterly dashboard against 2026 milestone.'],['Steward','Impact report with energy, emissions, and research outputs.']])}<h4>Case Study</h4><p>Mock case: Clara Voss, GSD parent and climate foundation trustee, is matched to a $28M Campus Electrification + Sustainable Design Lab ask. Gift officer Elena Foster coordinates GSD, FAS sustainability faculty, and the President’s climate briefing.</p>${mockNote()}`},

