function addSchoolGeoButtons(){
  const ids=['hbs','hms','fas','seas','hks','hls','gsd','hgse'];
  ids.forEach(key=>{
    const p=document.getElementById('ps-'+key);
    if(p&&!p.querySelector('.geo-action-btn')) p.insertAdjacentHTML('afterbegin',`<button class="geo-action-btn" onclick="openSchoolGeo('${key}')">Geo-giving & top prospects ↗</button>`);
  });
  const paneMap={fas:'fas',hbs:'hbs',hms:'hms',hks:'hks',hls:'hls',seas:'seas',gsd:'gsd',gse:'hgse'};
  Object.entries(paneMap).forEach(([pane,key])=>{
    const el=document.getElementById('school-'+pane);
    if(el&&!el.querySelector('.geo-action-btn')) el.insertAdjacentHTML('afterbegin',`<button class="geo-action-btn" onclick="openSchoolGeo('${key}')">Geo-giving & top prospects ↗</button>`);
  });
}

function openModal(id){
  const m=MODALS[id];
  if(!m){console.warn('No modal:',id);return;}
  document.getElementById('mTitle').textContent=m.t;
  document.getElementById('mSub').textContent=m.s||'';
  document.getElementById('mBody').innerHTML=m.b;
  document.getElementById('infoModal').classList.add('open');
}
function closeModal(){document.getElementById('infoModal').classList.remove('open');}
function openDynamicModal(title,sub,body){
  document.getElementById('mTitle').textContent=title;
  document.getElementById('mSub').textContent=sub||'';
  document.getElementById('mBody').innerHTML=body;
  document.getElementById('infoModal').classList.add('open');
}

