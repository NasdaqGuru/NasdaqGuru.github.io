  content:'VE · RI · TAS';
  position:absolute;bottom:20px;right:44px;pointer-events:none;
  font-family:var(--display);font-size:.75rem;
  letter-spacing:.4em;color:rgba(255,255,255,.25);
  text-transform:uppercase
}
.mast-inner{position:relative;z-index:1}
.mast-seal{
  display:inline-flex;align-items:center;justify-content:center;
  width:54px;height:54px;border-radius:50%;
  background:rgba(255,255,255,.1);border:2px solid rgba(182,134,44,.6);
  font-family:var(--display);font-size:1.4rem;font-weight:700;
  color:var(--gold2);margin-right:16px;flex-shrink:0
}
.mast-title-row{display:flex;align-items:center;margin-bottom:16px}
.mast-title{font-family:var(--display);font-size:clamp(1.6rem,4vw,2.6rem);
  font-weight:700;color:#fff;line-height:1.1;letter-spacing:-.02em}
.mast-subtitle{
  font-family:var(--serif);font-style:italic;
  font-size:1.05rem;color:rgba(255,255,255,.78);
  margin-bottom:16px;max-width:760px;line-height:1.55
}
.mast-meta{
  display:flex;flex-wrap:wrap;gap:28px 40px;
  border-top:1px solid rgba(255,255,255,.18);
  padding-top:18px;margin-top:4px
}
.mast-meta-item{font-family:var(--mono);font-size:.7rem;
  letter-spacing:.08em;color:rgba(255,255,255,.5);text-transform:uppercase}
.mast-meta-item strong{
  display:block;color:rgba(255,255,255,.9);
  font-family:var(--serif);font-size:.95rem;
  font-weight:600;text-transform:none;letter-spacing:0;margin-top:2px
}
.disc-strip{
  background:rgba(0,0,0,.35);
  padding:8px var(--page-x);font-family:var(--mono);font-size:.67rem;
  color:rgba(255,255,255,.45);letter-spacing:.06em;
  display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:6px;
  position:relative;z-index:3
}
.disc-strip a{color:var(--gold2);cursor:pointer;text-decoration:underline;font-size:.67rem}
#s-automation,#s-lifecycle,#s-roadmap,#s-future,#s-smarter,#s-appendix{padding-top:0}
#s-automation .wrap>div:first-child,#s-lifecycle .wrap>div:first-child,#s-roadmap .wrap>div:first-child,#s-future .wrap>div:first-child,#s-smarter .wrap>div:first-child,#s-appendix .wrap>div:first-child{margin-bottom:18px!important}
.disc-link{background:none;border:0;color:var(--gold2);cursor:pointer;text-decoration:underline;font:inherit;font-size:.67rem;letter-spacing:inherit;padding:0}
.disc-link:hover{color:#fff}
.modal,.disc-modal{font-family:var(--serif)}
.mbody,.mbody p,.mbody li,.mbody td,.mbody span,.disc-body{font-family:var(--serif)}
.mbody .detail-tile span,.modal-table td{font-size:.88rem;color:var(--mid)}
.modal-table th{font-family:var(--mono);font-size:.62rem;letter-spacing:.1em;text-transform:uppercase}
.modal-svg-chart{width:100%;height:auto;margin:8px 0 16px;border:1px solid var(--bdr);background:#fff}
.modal-legend{display:flex;gap:14px;flex-wrap:wrap;font-family:var(--mono);font-size:.62rem;color:var(--mid);margin:4px 0 14px}
.modal-legend i{display:inline-block;width:10px;height:10px;border-radius:2px;margin-right:5px;vertical-align:-1px}
.geo-footprint{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px;margin:18px 0 24px}
.geo-footprint-card{background:#fff;border:1px solid var(--bdr);border-top:3px solid var(--cr);padding:16px;border-radius:var(--r)}
.geo-footprint-card h4{margin-bottom:8px}.geo-footprint-card ul{margin-left:1.1em;font-size:.88rem;line-height:1.45}
.geo-footprint-card li{margin-bottom:.55em}
.geo-action-btn{display:inline-flex;align-items:center;gap:6px;margin:10px 0 14px;background:var(--cr);color:#fff;border:none;border-radius:var(--r);padding:8px 14px;font-family:var(--serif);font-weight:600;cursor:pointer}
.geo-action-btn:hover{background:var(--cr2)}
@media(max-width:900px){.geo-footprint{grid-template-columns:1fr}}

/* == SIDEBAR LAYOUT == */
.layout{display:block;min-height:calc(100vh - 220px)}
.sidebar{
  width:100%;position:sticky;top:0;z-index:250;
  background:rgba(247,242,232,.96);backdrop-filter:blur(10px);
  border-right:none;border-bottom:1px solid var(--bdr);padding:12px var(--page-x) 14px;
  display:grid;grid-template-columns:repeat(5,minmax(150px,1fr));gap:12px;
  scrollbar-width:thin;scrollbar-color:var(--bdr) transparent
}
.sidebar::-webkit-scrollbar{width:4px}
.sidebar::-webkit-scrollbar-track{background:transparent}
.sidebar::-webkit-scrollbar-thumb{background:var(--bdr)}
.main-content{min-width:0}
.nav-group{min-width:0}
.nav-section-label{
  font-family:var(--mono);font-size:.62rem;letter-spacing:.15em;
  text-transform:uppercase;color:var(--mid);
  padding:0 0 6px;margin-top:0
}
.nav-item{
  display:flex;align-items:center;gap:8px;
  padding:6px 8px;cursor:pointer;
  font-family:var(--serif);font-size:.9rem;color:var(--slate);
  border-left:none;border-bottom:2px solid transparent;
  transition:all .18s;line-height:1.35;
  background:none;border-top:none;border-right:none;
  width:100%;text-align:left
}
.nav-item:hover{background:rgba(164,16,52,.05);color:var(--cr)}
.nav-item.active{
  border-bottom-color:var(--cr);color:var(--cr);
  background:rgba(164,16,52,.06);font-weight:600
}
.nav-item.active::after{
  content:'Current';
  margin-left:auto;background:var(--cr);color:#fff;border-radius:999px;
  padding:2px 7px;font-family:var(--mono);font-size:.5rem;
  letter-spacing:.08em;text-transform:uppercase;font-weight:800
}
.nav-item-num{
  font-family:var(--mono);font-size:.65rem;color:var(--mid);
  flex-shrink:0;min-width:18px
}
.nav-item.active .nav-item-num{color:var(--cr)}
.nav-external{
  color:var(--ink);text-decoration:none;border-left-color:var(--gold);
  background:#fff8e8
}
.nav-external:hover{background:#f4e3b1;color:var(--ink)}
.nav-external::after{
  content:'↗';margin-left:auto;color:var(--gold);font-family:var(--mono);font-weight:800
}
.nav-divider{display:none}

/* == MOBILE NAV (hamburger) == */
.mobile-nav-bar{
  display:none;background:var(--cream);
  border-bottom:1px solid var(--bdr);
  padding:10px 16px;position:sticky;top:0;z-index:200;
  align-items:center;justify-content:space-between
}
.mobile-nav-title{font-family:var(--serif);font-size:.95rem;font-weight:600;color:var(--cr)}
.hamburger{
  background:none;border:1px solid var(--bdr);
  padding:6px 10px;cursor:pointer;border-radius:var(--r);
  font-size:1rem;color:var(--slate)
}
.mobile-nav-drawer{
  display:none;position:fixed;inset:0;
  background:rgba(0,0,0,.5);z-index:1000
}
.mobile-nav-drawer.open{display:block}
.mobile-nav-panel{
  position:absolute;left:0;top:0;bottom:0;
  width:260px;background:var(--cream);
  overflow-y:auto;padding:20px 0;
  box-shadow:4px 0 20px rgba(0,0,0,.2)
}
.mobile-nav-close{
  font-family:var(--mono);font-size:.7rem;letter-spacing:.1em;
  color:var(--mid);padding:0 24px 14px;cursor:pointer;
  background:none;border:none;display:block
}

/* == SECTION STRUCTURE == */
.section-eyebrow{
  font-family:var(--mono);font-size:.7rem;letter-spacing:.18em;
  text-transform:uppercase;color:var(--cr);margin-bottom:8px
}
.section-heading{
  font-family:var(--display);font-size:clamp(1.7rem,3.5vw,2.5rem);
  font-weight:700;color:var(--ink);letter-spacing:-.02em;
  margin-bottom:10px;line-height:1.15
}
.section-heading em{font-style:italic;color:var(--cr)}
.section-dek{
  font-family:var(--serif);font-size:1.05rem;
  color:var(--mid);max-width:680px;line-height:1.7;margin-bottom:36px
}
.section-rule{
  width:60px;height:3px;background:var(--cr);
  margin:16px 0 28px
}

/* == ACCORDION (collapsible content blocks) == */
.accordion{
  border:1px solid var(--bdr);border-radius:var(--r);
  margin-bottom:16px;overflow:hidden;background:#fff
}
.accordion-trigger{
  width:100%;display:flex;align-items:center;justify-content:space-between;
  padding:18px 24px;background:none;border:none;cursor:pointer;
  text-align:left;transition:background .15s;gap:12px
}
.accordion-trigger:hover{background:var(--cream)}
.accordion-trigger.open{background:var(--gold-pale);border-bottom:1px solid var(--bdr)}
.accordion-title-wrap{display:flex;align-items:center;gap:14px;flex:1;min-width:0}
.accordion-icon-wrap{
  width:32px;height:32px;border-radius:50%;
  background:var(--cream);border:1px solid var(--bdr);
  display:flex;align-items:center;justify-content:center;
  font-size:1.1rem;flex-shrink:0
}
.accordion-trigger.open .accordion-icon-wrap{background:var(--cr);border-color:var(--cr)}
.accordion-label{font-family:var(--mono);font-size:.65rem;
  letter-spacing:.12em;text-transform:uppercase;color:var(--mid);margin-bottom:2px}
.accordion-title{font-family:var(--display);font-size:1.05rem;
  font-weight:700;color:var(--slate);line-height:1.25}
.accordion-trigger.open .accordion-title{color:var(--cr2)}
.accordion-meta{
  font-family:var(--mono);font-size:.7rem;color:var(--mid);
  flex-shrink:0;text-align:right;line-height:1.4
}
.accordion-meta strong{display:block;color:var(--slate);font-size:.8rem}
.accordion-chevron{
  width:20px;height:20px;color:var(--mid);flex-shrink:0;
  transition:transform .25s;font-size:.8rem;
  display:flex;align-items:center;justify-content:center
}
.accordion-trigger.open .accordion-chevron{transform:rotate(180deg);color:var(--cr)}
.accordion-body{
  display:none;padding:28px 28px 24px;
  border-top:1px solid var(--bdr);background:#fff
}
.accordion-body.open{display:block}
/* Nested accordion */
.accordion-inner{border:1px solid var(--light);border-radius:var(--r);margin:12px 0}
.accordion-inner .accordion-trigger{padding:12px 18px}
.accordion-inner .accordion-body{padding:20px 20px 16px}

/* == SMARTER TABLE == */
.smarter-table{width:100%;border-collapse:collapse;font-size:.88rem;margin:16px 0}
.smarter-table th{
  background:var(--cr);color:#fff;padding:10px 14px;
  text-align:left;font-family:var(--mono);font-size:.65rem;
  letter-spacing:.1em;text-transform:uppercase;font-weight:500
}
.smarter-table th:first-child{width:110px}
.smarter-table td{
  padding:11px 14px;border-bottom:1px solid var(--light);
  vertical-align:top;line-height:1.55;font-size:.88rem
}
.smarter-table tr:hover td{background:var(--gold-pale)}
.smarter-table tr:last-child td{border-bottom:none}
.smarter-letter{
  font-family:var(--display);font-size:1.4rem;font-weight:700;
  color:var(--cr);line-height:1;display:block
}
.smarter-word{
  font-family:var(--mono);font-size:.6rem;letter-spacing:.08em;
  text-transform:uppercase;color:var(--mid)
}
.logic-flow{
  display:flex;gap:0;margin:18px 0;flex-wrap:wrap
}
.logic-node{
  flex:1;min-width:110px;background:var(--cream);
  border:1px solid var(--bdr);padding:14px 12px;
  text-align:center;position:relative
}
.logic-node::after{
  content:'→';position:absolute;right:-11px;top:50%;
  transform:translateY(-50%);color:var(--cr);font-size:1rem;
  z-index:2;background:var(--paper);padding:0 3px
}
.logic-node:last-child::after{display:none}
.logic-node-label{
  font-family:var(--mono);font-size:.62rem;letter-spacing:.1em;
  text-transform:uppercase;color:var(--cr);margin-bottom:4px
}
.logic-node-text{font-size:.82rem;color:var(--slate);line-height:1.45}

/* == KPI CARDS == */
.kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:32px}
.kpi-card{
  background:#fff;border:1px solid var(--bdr);
  border-top:3px solid var(--cr);padding:20px 18px;
  border-radius:var(--r);cursor:pointer;
  transition:box-shadow .2s,transform .2s
}
.kpi-card:hover{box-shadow:var(--shadow);transform:translateY(-2px)}
.kpi-card.gold{border-top-color:var(--gold)}
.kpi-card.gold .kpi-val{color:var(--gold)}
.kpi-card.green{border-top-color:var(--ok)}
.kpi-card.green .kpi-val{color:var(--ok)}
.kpi-card.blue{border-top-color:var(--info)}
.kpi-card.blue .kpi-val{color:var(--info)}
.kpi-lbl{font-family:var(--mono);font-size:.65rem;letter-spacing:.1em;
  text-transform:uppercase;color:var(--mid);margin-bottom:8px}
.kpi-val{font-family:var(--display);font-size:2rem;font-weight:700;
  color:var(--cr);line-height:1;margin-bottom:6px}
.kpi-delta{font-family:var(--mono);font-size:.72rem;color:var(--ok);font-weight:500}
.kpi-delta.neg{color:var(--warn)}
.kpi-hint{font-family:var(--mono);font-size:.62rem;color:var(--mid);margin-top:6px;opacity:.7}

/* == CHART WRAPPERS == */
.chart-wrap{
  position:relative;height:300px;background:#fff;
  padding:16px;border-radius:var(--r);border:1px solid var(--bdr);
  cursor:pointer;transition:box-shadow .2s
}
.chart-wrap:hover{box-shadow:var(--shadow)}
.chart-wrap.tall{height:380px}
.chart-wrap.sm{height:210px}
.chart-wrap.compact{height:170px;min-height:0}
.chart-wrap.compact canvas{max-height:110px!important}
.chart-lbl{font-family:var(--mono);font-size:.65rem;letter-spacing:.1em;
  text-transform:uppercase;color:var(--mid);margin-bottom:4px}
.chart-hint{font-family:var(--mono);font-size:.62rem;color:var(--cr);
  margin-top:4px;opacity:.55;text-align:right}
.chart-head{font-family:var(--display);font-size:1rem;font-weight:700;
  color:var(--ink);margin-bottom:12px}
.chart-row{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:24px}
.chart-row .wide{grid-column:span 2}
.chart-canvas-wrap{position:relative;height:240px}
.chart-canvas-wrap.tall{height:320px}
.chart-box.compact-launch{display:grid;grid-template-columns:46px 1fr auto;gap:12px;align-items:center;min-height:104px;padding:14px 16px}
.chart-icon{width:46px;height:46px;border-radius:50%;background:var(--cream);border:1px solid var(--bdr);display:flex;align-items:center;justify-content:center;color:var(--cr);font-size:1.35rem}
.chart-action{font-family:var(--mono);font-size:.58rem;letter-spacing:.08em;text-transform:uppercase;color:var(--cr);font-weight:800;white-space:nowrap}
.hidden-chart-source{position:absolute;left:-9999px;top:-9999px;width:360px;height:220px;overflow:hidden;pointer-events:none}

/* == CARDS == */
.card{background:#fff;border:1px solid var(--bdr);border-radius:var(--r);
  padding:26px;margin-bottom:20px;box-shadow:0 1px 3px rgba(0,0,0,.03)}
.card.cr-acc{border-left:4px solid var(--cr)}
.card.gd-acc{border-left:4px solid var(--gold)}
.card.gn-acc{border-left:4px solid var(--ok)}
.card.blue-acc{border-left:4px solid var(--info)}

/* == TABLES == */
table.data-table{width:100%;border-collapse:collapse;font-size:.87rem;margin:12px 0;background:#fff}
table.data-table th{
  background:var(--cr);color:#fff;padding:10px 14px;
  text-align:left;font-family:var(--mono);font-size:.65rem;
  letter-spacing:.08em;text-transform:uppercase;font-weight:500
}
table.data-table td{
  padding:10px 14px;border-bottom:1px solid var(--light);vertical-align:middle
}
table.data-table tr:hover td{background:var(--gold-pale)}
table.data-table tr:last-child td{border-bottom:none}
table{width:100%;border-collapse:collapse;font-size:.88rem;background:#fff}
table th{background:var(--cr);color:#fff;padding:10px 14px;text-align:left;font-family:var(--mono);font-size:.65rem;letter-spacing:.08em;text-transform:uppercase;font-weight:500}
table td{padding:10px 14px;border-bottom:1px solid var(--light);vertical-align:middle}

/* == BADGES == */
.badge{display:inline-block;padding:2px 8px;border-radius:2px;
  font-family:var(--mono);font-size:.62rem;letter-spacing:.05em;
  text-transform:uppercase;font-weight:600}
.badge-cr{background:#FAE8EB;color:var(--cr)}
.badge-gd{background:#FDF6E3;color:#7A5A00}
.badge-gn{background:#E6F4ED;color:#1A5C33}
.badge-blue{background:#E6EEF8;color:var(--info)}
.badge-warn{background:#FEF0E7;color:var(--warn)}
.badge-lt{background:var(--light);color:var(--slate)}
.badge-crimson{background:#FAE8EB;color:var(--cr)}
.badge-gold{background:#FDF6E3;color:#7A5A00}
.badge-green{background:#E6F4ED;color:#1A5C33}

/* == PILLS / STATUS == */
.pill{display:inline-block;padding:3px 10px;border-radius:20px;
  font-family:var(--mono);font-size:.62rem;font-weight:600;letter-spacing:.04em}
.pill-cr{background:var(--cr);color:#fff}
.pill-gd{background:var(--gold);color:#fff}
.pill-gn{background:var(--ok);color:#fff}
.pill-info{background:var(--info);color:#fff}
.pill-warn{background:var(--warn);color:#fff}
.pill-lt{background:var(--light);color:var(--slate)}
.status-dot{display:inline-flex;align-items:center;gap:7px;font-family:var(--mono);font-size:.62rem;letter-spacing:.04em;text-transform:uppercase;font-weight:800;color:var(--mid);white-space:nowrap}
.status-dot::before{content:'';width:9px;height:9px;border-radius:50%;background:var(--mid);box-shadow:0 0 0 3px rgba(0,0,0,.05)}
.status-dot.urgent::before{background:var(--warn)}
.status-dot.build::before{background:var(--info)}
.status-dot.pilot::before{background:var(--gold)}
.status-dot.on::before{background:var(--ok)}
.status-dot.done::before{background:var(--mid)}
.status-stack{display:grid;gap:7px;margin:12px 0}
.status-row{display:grid;grid-template-columns:2.4fr 1fr 1fr;gap:10px;align-items:center;background:#fff;border:1px solid var(--bdr);border-radius:var(--r);padding:10px 12px}
.status-title{font-weight:700;color:var(--ink);font-size:.88rem}
.status-meta{font-size:.76rem;color:var(--mid)}

/* == CALLOUT / ALERTS == */
.callout{padding:16px 20px;border-radius:var(--r);margin:14px 0;font-size:.9rem}
.callout h4{margin-bottom:6px}
.callout p{margin-bottom:0;font-size:.9rem}
.callout-gold{background:var(--gold-pale);border-left:4px solid var(--gold);color:#5A3A00}
.callout-cr{background:#FBF0F2;border-left:4px solid var(--cr);color:var(--cr3)}
.callout-gn{background:#EDFAF3;border-left:4px solid var(--ok);color:#1A4026}
.callout-info{background:#EEF4FC;border-left:4px solid var(--info);color:#0D2B52}
.callout-warn{background:#FEF6EE;border-left:4px solid var(--warn);color:#5A2300}

/* == PROGRESS BARS == */
.pbar-row{margin-bottom:18px}
.pbar-header{display:flex;justify-content:space-between;
  align-items:baseline;margin-bottom:5px}
.pbar-label{font-family:var(--serif);font-size:.9rem;font-weight:600;color:var(--slate)}
.pbar-sub{font-family:var(--mono);font-size:.65rem;color:var(--mid);margin-top:2px}
.pbar-val{font-family:var(--mono);font-size:.72rem;color:var(--mid)}
.pbar{height:8px;background:var(--light);border-radius:4px;overflow:hidden}
.pbar-fill{height:100%;background:var(--cr);border-radius:4px;transition:width 1.4s ease}
.pbar-fill.gold{background:var(--gold)}
.pbar-fill.green{background:var(--ok)}
.pbar-fill.blue{background:var(--info)}
.progress{height:9px;background:var(--light);border-radius:6px;overflow:hidden;margin-top:8px}
.progress-bar{height:100%;background:var(--cr);border-radius:6px;color:#fff;font-family:var(--mono);font-size:.58rem;line-height:9px;text-align:center;min-width:24px}
.progress-bar.gold{background:var(--gold)}.progress-bar.green{background:var(--ok)}

/* == TIMELINE == */
.timeline{position:relative;padding-left:28px;border-left:2px solid var(--bdr);margin:16px 0}
.tline-item{margin-bottom:24px;position:relative}
.tline-item::before{
  content:'';position:absolute;left:-34px;top:5px;
  width:12px;height:12px;background:var(--cr);
  border-radius:50%;border:2px solid #fff;box-shadow:0 0 0 2px var(--cr)
}
.tline-item.gold::before{background:var(--gold);box-shadow:0 0 0 2px var(--gold)}
.tline-item.green::before{background:var(--ok);box-shadow:0 0 0 2px var(--ok)}
.tline-date{font-family:var(--serif);font-style:italic;
  color:var(--cr);font-weight:700;font-size:.88rem}
.tline-title{font-weight:600;margin:2px 0 4px;font-size:.97rem;color:var(--ink)}
.tline-desc{font-size:.88rem;color:var(--mid);line-height:1.6}

/* == CODE BLOCKS == */
pre{background:#1A1E24;color:#E8E4DC;font-family:var(--mono);
  font-size:.78rem;line-height:1.7;padding:20px 24px;
  border-radius:var(--r);overflow-x:auto;margin:12px 0}
code.inline{background:var(--cream);color:var(--cr);
  padding:1px 6px;border-radius:2px;font-family:var(--mono);font-size:.83rem}
pre .kw{color:#E86070}pre .fn{color:#C9A84C}
pre .str{color:#88C68A}pre .cm{color:#5C6370;font-style:italic}
pre .num{color:#9B8AE8}

/* == INFO GRID (3-col stat blocks) == */
.stat-row{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin:16px 0}
.stat-block{background:var(--cream);border:1px solid var(--bdr);
  padding:16px;text-align:center;border-radius:var(--r)}
.stat-block .sv{font-family:var(--display);font-size:1.75rem;
  font-weight:700;color:var(--cr);line-height:1}
.stat-block.gold .sv{color:var(--gold)}
.stat-block.green .sv{color:var(--ok)}
.stat-block.blue .sv{color:var(--info)}
.stat-block .sl{font-family:var(--mono);font-size:.62rem;
  letter-spacing:.1em;text-transform:uppercase;color:var(--mid);margin-top:4px}

/* == DETAIL GRID / INFOGRAPHIC == */
.detail-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:20px}
.detail-tile{
  background:#fff;border:1px solid var(--bdr);
  padding:16px 14px;border-radius:var(--r)
}
.detail-tile strong{display:block;font-family:var(--display);
  font-size:1.1rem;color:var(--cr);margin-bottom:4px}
.detail-tile span{font-size:.85rem;color:var(--mid);line-height:1.5}

/* == STEP FLOW == */
.sflow{display:flex;gap:0;margin:16px 0;flex-wrap:wrap}
.sbox{
  flex:1;min-width:100px;background:var(--cream);
  border:1px solid var(--bdr);padding:13px 10px;
  text-align:center;position:relative
}
.sbox::after{
  content:'→';position:absolute;right:-10px;top:50%;
  transform:translateY(-50%);color:var(--cr);font-size:.9rem;z-index:2
}
.sbox:last-child::after{display:none}
.snum{font-family:var(--mono);font-size:.6rem;color:var(--cr);
  letter-spacing:.08em;margin-bottom:3px;text-transform:uppercase}
.stitle{font-size:.85rem;font-weight:600;color:var(--slate)}
.sdesc{font-size:.75rem;color:var(--mid);margin-top:3px;line-height:1.4}

/* == SCHOOL TABS == */
.school-tabs{display:flex;flex-wrap:wrap;gap:4px;
  margin:16px 0 8px;border-bottom:2px solid var(--bdr)}
.school-tab{
  padding:7px 12px;cursor:pointer;background:#fff;
  border:1px solid var(--bdr);border-bottom:none;
  border-radius:var(--r) var(--r) 0 0;
  font-family:var(--mono);font-size:.68rem;letter-spacing:.06em;
  text-transform:uppercase;color:var(--mid);transition:all .15s
}
.school-tab:hover{background:var(--cream)}
.school-tab.active{background:var(--cr);color:#fff;border-color:var(--cr)}
.school-pane{display:none;padding:22px;background:#fff;
  border:1px solid var(--bdr);border-radius:0 var(--r) var(--r) var(--r);border-top:none}
.school-pane.active{display:block;animation:fadeUp .25s ease}

/* == SUB TABS == */
.sub-tabs{display:flex;flex-wrap:wrap;gap:4px;margin:16px 0 8px;border-bottom:2px solid var(--bdr)}
.sub-tab{
  padding:7px 14px;cursor:pointer;background:#fff;
  border:1px solid var(--bdr);border-bottom:none;
  border-radius:var(--r) var(--r) 0 0;
  font-family:var(--mono);font-size:.68rem;letter-spacing:.06em;
  text-transform:uppercase;color:var(--mid);transition:all .15s
}
.sub-tab:hover{background:var(--cream)}
.sub-tab.active{background:var(--cr);color:#fff;border-color:var(--cr)}
.sub-pane{display:none;padding:22px;background:#fff;
  border:1px solid var(--bdr);border-radius:0 var(--r) var(--r) var(--r);border-top:none}
.sub-pane.active{display:block;animation:fadeUp .25s ease}
.sub-panel{display:none}.sub-panel.active{display:block}

/* == HEATMAP == */
.heatmap-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:4px;margin:12px 0}
.heat-cell{padding:10px 5px;text-align:center;font-size:.65rem;
  border-radius:2px;color:#fff;font-weight:600;cursor:default;
  transition:transform .15s}
.heat-cell:hover{transform:scale(1.07);z-index:2;position:relative}
.heat-cell{position:relative;min-height:54px;display:flex;flex-direction:column;justify-content:center}
.heat-cell .val{font-family:var(--display);font-size:1rem;line-height:1;color:#fff}
.heat-cell .lbl{font-family:var(--mono);font-size:.55rem;line-height:1.2;color:rgba(255,255,255,.92)}
.hover-pop{
  display:none;position:absolute;left:50%;bottom:calc(100% + 8px);transform:translateX(-50%);
  width:min(260px,80vw);background:#fff;color:var(--ink);border:1px solid var(--bdr);
  border-top:3px solid var(--cr);box-shadow:var(--shadow-lg);padding:12px 14px;text-align:left;
  font-size:.75rem;line-height:1.45;z-index:40;border-radius:var(--r)
}
.heat-cell:hover .hover-pop,.heat-cell:focus .hover-pop{display:block}
.hover-pop strong{display:block;color:var(--cr);margin-bottom:4px}

/* == GEO TABS == */
.geo-map-box{background:#fff;border:1px solid var(--bdr);padding:24px;margin-bottom:24px;border-radius:var(--r)}
.geo-tabs{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:16px}
.geo-tab-btn{
  padding:5px 12px;font-family:var(--mono);font-size:.67rem;
  letter-spacing:.07em;text-transform:uppercase;
  background:var(--cream);border:1px solid var(--bdr);
  color:var(--mid);cursor:pointer;border-radius:var(--r);transition:all .2s
}
.geo-tab-btn.active{background:var(--cr);color:#fff;border-color:var(--cr)}
.geo-tab-btn:hover:not(.active){border-color:var(--cr);color:var(--cr)}

/* Unified report cards and infographic blocks */
.chart-box,.kpi,.infographic-card,.automation-explainer,.wow-panel{
  background:#fff;border:1px solid var(--bdr);border-radius:var(--r);box-shadow:0 1px 3px rgba(0,0,0,.03)
}
.chart-box{padding:16px;cursor:pointer;transition:box-shadow .2s,transform .2s}
.chart-box:hover,.clickable-card:hover{box-shadow:var(--shadow);transform:translateY(-1px)}
.chart-title,.chart-label{font-family:var(--mono);font-size:.65rem;letter-spacing:.1em;text-transform:uppercase;color:var(--mid);margin-bottom:4px}
.chart-headline{font-size:.86rem;color:var(--slate);line-height:1.45;margin-bottom:10px}
.kpi{padding:18px;border-top:3px solid var(--cr);cursor:pointer}
.kpi.gold{border-top-color:var(--gold)}.kpi.green{border-top-color:var(--ok)}
.kpi .label,.kpi-label{font-family:var(--mono);font-size:.65rem;letter-spacing:.1em;text-transform:uppercase;color:var(--mid);margin-bottom:7px}
.kpi .value,.kpi-value{font-family:var(--display);font-size:1.8rem;line-height:1;color:var(--cr);font-weight:700}
.kpi.gold .value{color:var(--gold)}.kpi.green .value{color:var(--ok)}
.kpi .delta,.kpi-expand,.hint{font-family:var(--mono);font-size:.68rem;color:var(--mid);margin-top:6px}
.infographic-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:16px;margin:16px 0 24px}
.infographic-card{padding:20px;border-top:3px solid var(--cr)}
.infographic-icon{font-size:1.55rem;margin-bottom:8px}
.infographic-title{font-family:var(--display);font-size:1.05rem;font-weight:700;color:var(--cr2);margin-bottom:6px;line-height:1.25}
.infographic-desc{font-size:.9rem;color:var(--mid);line-height:1.62}
.section-infographic-auto{margin:18px 0 28px}
.section-infographic-auto .infographic-card{padding:16px;min-height:138px}
.section-infographic-auto .infographic-icon{font-family:var(--mono);font-size:.78rem;letter-spacing:.1em;color:var(--gold);font-weight:800}
.section-infographic-auto .infographic-title{font-size:.98rem}
.section-infographic-auto .infographic-desc{font-size:.82rem;line-height:1.55}
.masthead{padding-bottom:0}
.mast-title{max-width:1040px}
.mast-subtitle{max-width:960px}
.mast-meta{grid-template-columns:repeat(5,minmax(0,1fr));gap:10px}
.companion-banner{display:grid;grid-template-columns:auto 1fr;align-items:center;gap:14px;padding:10px 22px;background:#141414;border-bottom:1px solid rgba(255,255,255,.12)}
.companion-label{white-space:nowrap;color:var(--gold2)}
.companion-title{font-size:.88rem;line-height:1.35;color:rgba(255,255,255,.82)}
.progress-mini{margin-top:8px}
.progress-mini-head{display:flex;justify-content:space-between;gap:10px;font-family:var(--mono);font-size:.58rem;letter-spacing:.08em;text-transform:uppercase;color:var(--mid);margin-bottom:5px}
.progress-track{height:8px;background:var(--light);border:1px solid var(--bdr);border-radius:99px;overflow:hidden}
.progress-fill{height:100%;width:var(--pct,0%);background:linear-gradient(90deg,var(--cr),var(--gold));border-radius:99px}
.progress-fill.green{background:linear-gradient(90deg,#1A5C33,var(--ok))}
.progress-fill.blue{background:linear-gradient(90deg,#0D47A1,var(--info))}
.progress-fill.gold{background:linear-gradient(90deg,#8A6500,var(--gold))}
.status-row .progress-mini{grid-column:1 / -1;margin-top:4px}
.ai4-redesign{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:14px;margin:14px 0 22px}
.ai4-card{background:#fff;border:1px solid var(--bdr);border-radius:var(--r);box-shadow:var(--shadow);overflow:hidden}
.ai4-cap{padding:14px 16px;color:#fff;background:var(--cr)}
.ai4-card:nth-child(2) .ai4-cap{background:var(--gold);color:#f9f8f7}
.ai4-card:nth-child(3) .ai4-cap{background:var(--info)}
.ai4-card:nth-child(4) .ai4-cap{background:var(--ok)}
.ai4-num{font-family:var(--mono);font-size:.58rem;letter-spacing:.12em;text-transform:uppercase;opacity:.75}
.ai4-title{font-family:var(--display);font-size:1.08rem;font-weight:700;margin-top:4px;line-height:1.2}
.ai4-body{padding:14px 16px}
.ai4-body p{font-size:.82rem;line-height:1.55;color:var(--mid);margin:0 0 10px}
.ai4-stat{display:flex;justify-content:space-between;gap:8px;font-family:var(--mono);font-size:.62rem;color:var(--cr);font-weight:800}
.leadership-redesign{background:#fff;border:1px solid var(--bdr);border-left:4px solid var(--gold);border-radius:var(--r);box-shadow:var(--shadow);padding:18px;margin-bottom:22px}
.leadership-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
.leadership-card{background:var(--cream);border:1px solid var(--bdr);border-top:3px solid var(--cr);border-radius:var(--r);padding:13px;cursor:pointer}
.leadership-card:nth-child(2){border-top-color:var(--gold)}
.leadership-card:nth-child(3){border-top-color:var(--info)}
.leadership-card:nth-child(4){border-top-color:var(--ok)}
.leadership-card h4{font-family:var(--display);font-size:.98rem;margin:0 0 6px;color:var(--ink)}
.leadership-card p{font-size:.8rem;line-height:1.48;color:var(--mid);margin:0}
.chart-card-row{display:grid!important;grid-template-columns:repeat(2,minmax(0,1fr))!important;gap:16px!important}
.chart-card-row .chart-wrap,.strategy-chart-card{height:240px!important;min-height:0;background:#fff;border:1px solid var(--bdr);border-top:4px solid var(--cr);border-radius:var(--r);box-shadow:var(--shadow);padding:16px}
#s-strategy .chart-wrap{background:#fff;border:1px solid var(--bdr);border-top:4px solid var(--cr);border-radius:var(--r);box-shadow:var(--shadow);padding:14px}
#s-strategy .accordion-body .callout-info h4:first-child{display:none}
.theme-popup-row{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:12px;margin:14px 0}
.theme-popup-card{background:#fff;border:1px solid var(--bdr);border-left:4px solid var(--gold);border-radius:var(--r);padding:14px;cursor:pointer;box-shadow:var(--shadow)}
.theme-popup-card h4{font-family:var(--display);font-size:1rem;margin:0 0 5px}
.theme-popup-card p{font-size:.82rem;line-height:1.5;color:var(--mid);margin:0}
#s-matrix .data-table td:nth-child(2){min-width:170px}
#s-pipeline .infographic-grid:not(.section-infographic-auto) .infographic-card{display:grid;grid-template-columns:44px 1fr;column-gap:12px;align-items:start;border-top:0;border-left:4px solid var(--cr)}
#s-pipeline .infographic-grid:not(.section-infographic-auto) .infographic-icon{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:var(--cream);border:1px solid var(--bdr);font-family:var(--mono);font-size:.72rem;color:var(--cr);font-weight:800;margin:0}
#s-pipeline .infographic-grid:not(.section-infographic-auto) .mini-link{grid-column:2}
.lifecycle-cards{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px;margin:16px 0 22px}
.lifecycle-card{background:#fff;border:1px solid var(--bdr);border-top:4px solid var(--cr);border-radius:var(--r);padding:16px;box-shadow:var(--shadow)}
.lifecycle-card:nth-child(2){border-top-color:var(--gold)}
.lifecycle-card:nth-child(3){border-top-color:var(--info)}
.lifecycle-card h3{font-family:var(--display);font-size:1rem;margin:0 0 6px;color:var(--ink)}
.lifecycle-card p{font-size:.82rem;color:var(--mid);line-height:1.52;margin:0}
#s-future .infographic-grid{grid-template-columns:repeat(3,minmax(0,1fr))!important}
#s-resilience .ra-synth-grid{grid-template-columns:repeat(3,minmax(0,1fr))!important}
#s-resilience .ra-main-grid{grid-template-columns:repeat(3,minmax(0,1fr))}
#s-ecosystem .ecosystem-redesign{background:#fff;border:1px solid var(--bdr);border-radius:var(--r);box-shadow:var(--shadow);padding:18px}
#s-ecosystem .ecosystem-spine{grid-template-columns:repeat(2,minmax(0,1fr))}
#s-ecosystem .eco-flow{grid-template-columns:repeat(5,minmax(0,1fr))}
#s-ecosystem .eco-proof{grid-template-columns:repeat(3,minmax(0,1fr))}
.appendix-foresight-top{background:var(--ink);color:#fff;border-radius:var(--r);padding:18px 20px;margin:0 0 20px;display:grid;grid-template-columns:1fr auto;gap:16px;align-items:center}
.appendix-foresight-top h2{font-family:var(--display);font-size:1.25rem;margin:0 0 5px;color:#fff}
.appendix-foresight-top p{font-size:.88rem;color:rgba(255,255,255,.72);margin:0}
.appendix-foresight-top a{background:var(--gold);color:#181818;text-decoration:none;border-radius:3px;padding:10px 14px;font-family:var(--mono);font-size:.62rem;letter-spacing:.08em;text-transform:uppercase;font-weight:800}
@media(max-width:980px){
  .mast-meta,.ai4-redesign,.leadership-grid,#s-future .infographic-grid,#s-resilience .ra-synth-grid,.lifecycle-cards{grid-template-columns:1fr!important}
  .chart-card-row,.theme-popup-row{grid-template-columns:1fr!important}
  .appendix-foresight-top{grid-template-columns:1fr}
}
.automation-explainer{padding:20px;margin:18px 0}
.step-flow{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:10px;margin-top:12px}
.step-box{background:var(--cream);border:1px solid var(--bdr);padding:12px;border-radius:var(--r)}
.step-num{font-family:var(--mono);font-size:.6rem;color:var(--cr);letter-spacing:.1em;text-transform:uppercase}
.step-title{font-weight:700;color:var(--ink);font-size:.9rem;margin:3px 0}
.step-desc{font-size:.78rem;color:var(--mid);line-height:1.45}
.impact-band{display:grid;grid-template-columns:minmax(0,1.1fr) minmax(280px,.9fr);gap:18px;align-items:stretch;margin:16px 0}
.wow-panel{padding:20px}
.priority-match-grid{display:grid;gap:8px;margin-top:12px}
.priority-match{display:grid;grid-template-columns:34px 1fr;gap:10px;align-items:center;background:var(--cream);border:1px solid var(--bdr);padding:9px 10px}
.priority-match strong{font-family:var(--display);font-size:1.05rem;color:var(--cr);text-align:center}
.priority-match span{font-size:.86rem;color:var(--slate);line-height:1.35}
.modal-table{width:100%;border-collapse:collapse;margin:12px 0;font-size:.83rem}
.modal-table th{background:var(--cr2);color:#fff}
.modal-table td,.modal-table th{padding:9px 10px;border-bottom:1px solid var(--light);vertical-align:top}
.big-stat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;margin-bottom:16px}
.big-stat{background:#FAE8EB;border:1px solid #E9C8D0;padding:14px;text-align:center}
.big-stat.green{background:#E6F4ED;border-color:#C8E6D2}.big-stat.gold{background:#FDF6E3;border-color:#EAD49D}
.big-stat strong{display:block;font-family:var(--display);font-size:1.55rem;color:var(--cr)}
.big-stat.green strong{color:var(--ok)}.big-stat.gold strong{color:var(--gold)}
.big-stat span{font-family:var(--mono);font-size:.62rem;text-transform:uppercase;color:var(--mid)}
.mini-bars{display:grid;gap:7px;margin:10px 0 16px}.mini-bar,.mini-bar-row{display:grid;grid-template-columns:58px 1fr 58px;gap:8px;align-items:center;font-family:var(--serif);font-size:.78rem;color:var(--mid)}
.mini-track{height:10px;background:var(--cream);border:1px solid var(--bdr);border-radius:10px;overflow:hidden}.mini-fill{height:100%;background:linear-gradient(90deg,var(--cr),var(--gold));border-radius:10px}
.mini-bar-track{height:8px;background:var(--light);border-radius:5px;overflow:hidden}.mini-bar-fill{height:100%;background:var(--cr);border-radius:5px}
.metric-link{color:var(--cr);font-weight:700;cursor:pointer;text-decoration:underline;text-decoration-thickness:1px;text-underline-offset:2px}

/* == MODAL == */
