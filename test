      item.classList.toggle('is-active',active);
      item.setAttribute('aria-current',active?'page':'false');
      var cb=item.querySelector('.avp-tracker-check');if(cb)cb.checked=!!s[id];
    });
    document.querySelectorAll('.sb-path-group').forEach(function(group){
      group.classList.toggle('is-current',!!group.querySelector('.sb-path-item.is-active'));
    });
    document.querySelectorAll('.nav-item[data-tab],.tab-btn[data-tab]').forEach(function(btn){
      btn.classList.toggle('active',btn.getAttribute('data-tab')===cur || (btn.dataset&&btn.dataset.tab===cur));
    });
    updateFeedbackLink(total,read);
    window.UAAD_INDEX_REVIEW_SECTIONS=rows;
  }
  function setRead(id,value){if(!id)return;var s=readState();s[id]=!!value;writeState(s);try{localStorage.setItem(LAST,id);}catch(e){}refreshTrackReview();}
  function resetReview(){try{localStorage.removeItem(STORAGE);localStorage.removeItem(START);localStorage.removeItem(FEEDBACK);sessionStorage.removeItem(STORAGE+'_complete');}catch(e){}var note=document.getElementById('feedbackNote');if(note)note.value='';refreshTrackReview();}
  function nextUnread(){var s=readState(), rows=flat();var row=rows.find(function(r){return !s[r.id];})||rows.find(function(r){return r.id!==current();})||rows[0];if(row)openSection(row.id);}
  ready(function(){
    rebuildTrackReview();
    document.addEventListener('click',function(e){
      var mark=e.target.closest&&e.target.closest('#markCurrentRead');
      var next=e.target.closest&&e.target.closest('#nextUnreadSection');
      var reset=e.target.closest&&e.target.closest('#resetExecutivePath,#resetExecutivePathBottom,#resetExecutivePathModal,#resetExecutivePathCheck');
      var resume=e.target.closest&&e.target.closest('#resumeLastVisit');
      var item=e.target.closest&&e.target.closest('.sb-path-item[data-target]');
      var checkbox=e.target.closest&&e.target.closest('.avp-tracker-check');
      if(mark){e.preventDefault();e.stopImmediatePropagation();setRead(current(),true);return;}
      if(next){e.preventDefault();e.stopImmediatePropagation();nextUnread();return;}
      if(reset){e.preventDefault();e.stopImmediatePropagation();resetReview();return;}
      if(resume){e.preventDefault();e.stopImmediatePropagation();var last=null;try{last=localStorage.getItem(LAST);}catch(err){}openSection(last||current());return;}
      if(checkbox&&item){e.stopImmediatePropagation();setRead(item.getAttribute('data-target'),checkbox.checked);return;}
      if(item){e.preventDefault();e.stopImmediatePropagation();openSection(item.getAttribute('data-target'));return;}
    },true);
    document.addEventListener('keydown',function(e){var item=e.target.closest&&e.target.closest('.sb-path-item[data-target]');if(item&&(e.key==='Enter'||e.key===' ')){e.preventDefault();openSection(item.getAttribute('data-target'));}},true);
    document.addEventListener('input',function(e){if(e.target&&e.target.id==='feedbackNote')refreshTrackReview();});
    var old=window.activateTab;
    if(typeof old==='function'&&!old.__uaadTrackReviewMerged){
      var wrapped=function(id){var r=old.apply(this,arguments);try{localStorage.setItem(LAST,id||current());}catch(e){}setTimeout(refreshTrackReview,40);return r;};
      wrapped.__uaadTrackReviewMerged=true;window.activateTab=wrapped;
    }
    setInterval(refreshTrackReview,1200);
    refreshTrackReview();
  });
})();
</script>


