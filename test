document.addEventListener('DOMContentLoaded', () => {
  enhanceTopIndex();
  addSectionInfographics();
  pageEnhancements();
  const accessKey='hv4_portfolio_viewer_access';
  const accessForm=document.getElementById('accessForm');
  const accessError=document.getElementById('accessError');
  const viewerEmail=document.getElementById('viewerEmail');
  const accessAck=document.getElementById('accessAck');
  const unlockReport=()=>document.body.classList.remove('access-locked');
  try{
    const saved=JSON.parse(localStorage.getItem(accessKey)||'null');
    if(saved&&saved.email&&saved.acknowledged) unlockReport();
  }catch(e){}
  if(accessForm){
    accessForm.addEventListener('submit',e=>{
      e.preventDefault();
      const email=(viewerEmail.value||'').trim();
      const valid=/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
      if(!valid||!accessAck.checked){
        accessError.classList.add('show');
        return;
      }
      localStorage.setItem(accessKey,JSON.stringify({email,acknowledged:true,viewedAt:new Date().toISOString()}));
      accessError.classList.remove('show');
      unlockReport();
    });
  }
  document.querySelectorAll('.tab-btn').forEach(b=>{
    const on=b.classList.contains('active');
    b.setAttribute('role','tab');
    b.setAttribute('aria-selected',on?'true':'false');
  });
  document.querySelectorAll('.section-panel').forEach(p=>{
    p.setAttribute('role','tabpanel');
    p.toggleAttribute('hidden',!p.classList.contains('active'));
  });
  setTimeout(()=>{initSection('s-opportunity');pageEnhancements();}, 150);
  // Show the executive reading map once per browser session.
  if (!sessionStorage.getItem('review_map_seen')) {
    setTimeout(openReviewMap, 700);
    sessionStorage.setItem('review_map_seen', '1');
  }
  // The disclaimer remains available from the masthead link.
  if (false && !sessionStorage.getItem('disc_seen')) {
    setTimeout(() => {
      const modal = document.getElementById('discModal');
      if (modal) modal.classList.add('open');
    }, 800);
    sessionStorage.setItem('disc_seen', '1');
  }
});
</script>
