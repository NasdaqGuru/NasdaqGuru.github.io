function modalBarChart(rows,max){
  const h=34+rows.length*26,w=720,left=120,right=86,barH=14,gap=12;
  return `<svg class="modal-svg-chart" viewBox="0 0 ${w} ${h}" role="img" aria-label="Modal bar chart">${rows.map((r,i)=>{
    const y=26+i*(barH+gap), bw=Math.max(6,Math.round((w-left-right)*(r[1]/max)));
    const fill=r[2]||'var(--cr)';
    return `<text x="14" y="${y+11}" font-family="EB Garamond, Georgia, serif" font-size="13" fill="var(--mid)">${r[0]}</text><rect x="${left}" y="${y}" width="${w-left-right}" height="${barH}" fill="var(--cream)" stroke="var(--bdr)"/><rect x="${left}" y="${y}" width="${bw}" height="${barH}" fill="${fill}"/><text x="${left+bw+8}" y="${y+11}" font-family="Source Code Pro, monospace" font-size="11" fill="var(--ink)">${r[3]||'$'+r[1]+'M'}</text>`;
  }).join('')}</svg>`;
}
