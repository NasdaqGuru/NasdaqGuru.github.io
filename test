/* ======================================
   DISCLAIMER + INIT
====================================== */
document.addEventListener('DOMContentLoaded',()=>{
  enhanceTopIndex();
  addSectionInfographics();
  pageEnhancements();
  document.querySelectorAll('[data-disclaimer-link]').forEach(a=>a.addEventListener('click',openDisclaimer));
  addSchoolGeoButtons();
  // Fix active state on first load
  document.querySelectorAll('.section-panel').forEach(p=>{
    const on=p.id==='s-opportunity';
    p.toggleAttribute('hidden',!on);
    p.classList.toggle('active',on);
  });
  setTimeout(()=>{initSection('s-opportunity');pageEnhancements();}, 200);
  if(false && !sessionStorage.getItem('disc_seen')){
    setTimeout(()=>document.getElementById('discModal').classList.add('open'), 700);
    sessionStorage.setItem('disc_seen','1');
  }
  // Animate success bars when SMARTER section is viewed
  const obs = new IntersectionObserver(entries=>{
    entries.forEach(e=>{
      if(e.isIntersecting){
        e.target.querySelectorAll('.success-bar-fill').forEach(b=>{
          b.style.width = b.style.width; // trigger reflow
        });
      }
    });
  },{threshold:0.1});
  document.querySelectorAll('#s-smarter').forEach(el=>obs.observe(el));
});

document.addEventListener('keydown',e=>{
  if(e.key==='Escape'){
    closeModal();
    document.getElementById('chartModal').classList.remove('open');
    document.getElementById('discModal').classList.remove('open');
    closeReviewMap();
  }}
);
