<script id="final-popup-title-contrast-script">
(function(){
  function ready(fn){document.readyState==='loading'?document.addEventListener('DOMContentLoaded',fn):fn();}
  function enforce(){
    document.querySelectorAll('.mhdr,.modal-hdr,.modal-header,.popup-header,.dialog-header,.disc-modal-hdr,.review-map-hdr,.avp-complete-head,.report-search-head,.link-rec-head').forEach(function(h){
      h.style.setProperty('background','linear-gradient(135deg,#4e0818 0%,#6f0b22 44%,#A41034 100%)','important');
      h.style.setProperty('color','#fff','important');
      h.querySelectorAll('*').forEach(function(x){x.style.setProperty('color','#fff','important');});
    });
    document.querySelectorAll('.modal,.modal-box,.disc-modal,.review-map,.review-map-modal,.avp-complete-modal,.report-search-modal,.link-rec-modal,.popup,.dialog').forEach(function(m){
      m.style.setProperty('background','#fff','important');
      m.style.setProperty('color','#111827','important');
    });
    ['s-ecosystem','s-datamodels','s-resilience'].forEach(function(id){
      var root=document.getElementById(id); if(!root) return;
      var intro=id==='s-resilience'?root.querySelector('.section-intro'):root.querySelector(':scope > .wrap > div:first-child');
      if(!intro) return;
      intro.style.setProperty('background','radial-gradient(660px 220px at 8% -18%,rgba(242,217,154,.26),transparent 62%),linear-gradient(135deg,#4e0818 0%,#6f0b22 46%,#A41034 100%)','important');
      intro.style.setProperty('color','#fff','important');
      intro.querySelectorAll('.section-heading,.section-heading *, .section-dek').forEach(function(x){x.style.setProperty('color','#fff','important');});
      intro.querySelectorAll('.section-heading em,.section-eyebrow').forEach(function(x){x.style.setProperty('color','#F2D99A','important');});
    });
  }
  ready(function(){enforce(); setTimeout(enforce,120); setTimeout(enforce,700);});
})();
</script>
<script id="final-popup-title-contrast-observer">
(function(){
  function applyContrast(root){
    root=(root&&root.querySelectorAll)?root:document;
    root.querySelectorAll('.mhdr,.modal-hdr,.modal-header,.popup-header,.dialog-header,.disc-modal-hdr,.review-map-hdr,.avp-complete-head,.report-search-head,.link-rec-head').forEach(function(h){
      h.style.setProperty('background','linear-gradient(135deg,#4e0818 0%,#6f0b22 44%,#A41034 100%)','important');
      h.style.setProperty('color','#fff','important');
      h.querySelectorAll('*').forEach(function(x){x.style.setProperty('color','#fff','important');});
    });
    root.querySelectorAll('.modal,.modal-box,.disc-modal,.review-map,.review-map-modal,.avp-complete-modal,.report-search-modal,.link-rec-modal,.popup,.dialog').forEach(function(m){
      m.style.setProperty('background','#fff','important');
      m.style.setProperty('color','#111827','important');
    });
  }
  function ready(fn){document.readyState==='loading'?document.addEventListener('DOMContentLoaded',fn):fn();}
  ready(function(){
    applyContrast(document);
    new MutationObserver(function(records){
      records.forEach(function(r){r.addedNodes.forEach(function(n){if(n.nodeType===1) applyContrast(n);});});
    }).observe(document.body,{childList:true,subtree:true});
  });
})();
</script>
