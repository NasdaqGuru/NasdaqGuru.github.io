<script id="uaad-theme-rebuild-v8-script">
(function(){
  function ready(fn){document.readyState==='loading'?document.addEventListener('DOMContentLoaded',fn):fn();}
  function cleanForceClasses(root){
    (root||document).querySelectorAll('.uaad-force-white-surface,.uaad-force-black-surface,.uaad-force-white-text,.uaad-force-black-text').forEach(function(el){
      if(!el.matches('#sidebar,#sidebar *,.future-reporting-head,.future-reporting-head *')){
        el.classList.remove('uaad-force-white-surface','uaad-force-black-surface','uaad-force-white-text','uaad-force-black-text');
        if(el.getAttribute('style')&&/color:\s*(#fff|white|#111827)/i.test(el.getAttribute('style'))){
          el.style.removeProperty('color');
        }
      }
    });
  }
  function bindFutureTabs(){
    var root=document.querySelector('#s-matrix .future-reporting-sample');
    if(!root)return;
    root.style.display='block';root.style.visibility='visible';root.style.opacity='1';root.classList.add('js-ready');
    var panels=root.querySelectorAll('.future-reporting-panel');
    if(panels.length&&!root.querySelector('.future-reporting-panel.active'))panels[0].classList.add('active');
    root.querySelectorAll('.future-reporting-tab').forEach(function(btn,idx){
      if(!btn.dataset.futureTab){var p=panels[idx]; if(p)btn.dataset.futureTab=p.id;}
      btn.type='button';
      if(btn.dataset.uaadThemeBound)return;
      btn.dataset.uaadThemeBound='1';
      btn.addEventListener('click',function(e){
        e.preventDefault();
        var target=btn.getAttribute('data-future-tab');
        root.querySelectorAll('.future-reporting-tab').forEach(function(b){var on=b===btn;b.classList.toggle('active',on);b.setAttribute('aria-selected',on?'true':'false');});
        root.querySelectorAll('.future-reporting-panel').forEach(function(p){p.classList.toggle('active',p.id===target);});
      });
    });
  }
  function refineReadingIndex(){
    var title=document.querySelector('#sidebar .sb-path-title'); if(title)title.textContent='Reading Index';
    var kicker=document.querySelector('#sidebar .sb-path-kicker'); if(kicker)kicker.textContent='Section Review';
    var note=document.querySelector('#sidebar .sb-path-sync-note'); if(note)note.remove();
    document.querySelectorAll('#sidebar .sb-path-copy').forEach(function(copy){
      var b=copy.querySelector('b'), strong=copy.querySelector('strong');
      if(b&&strong){b.textContent=b.textContent.trim(); strong.textContent=strong.textContent.trim();}
    });
  }
  function classifySurfaces(){
    var surfaceSelector=['.proposal-card-cap','.card-cap','.ise-card-cap','.se-header','.psws-header','.ra-opening-strip','.ra-synthesis','.ise-arch-band','.ise-emeritus-bar','.matrix-node.center','.accordion-trigger','.future-reporting-head','.future-reporting-tab.active','.comp-tab.active','.eco23-tab.active','.tab-btn.active','.disc-modal-hdr','.review-map-hdr','.avp-complete-head','.link-rec-head','.report-search-head','.unvisited-rec-head'].join(',');
    document.querySelectorAll(surfaceSelector).forEach(function(el){el.classList.add('uaad-surface-dark');el.classList.remove('uaad-surface-light');});
    var lightSelector=['.card','.proposal-card','.metric-card','.dashboard-card','.outline-card','.unit-card','.callout','.chart-wrap','.chart-box','.detail-tile','.future-reporting-card','.future-reporting-panel','.comp-card','.accordion-content','.tline-item','.kpi-card','.ai-impact-card','.leadership-card'].join(',');
    document.querySelectorAll(lightSelector).forEach(function(el){if(!el.closest('.uaad-surface-dark')){el.classList.add('uaad-surface-light');}});
  }
  function moveUtilityOrder(){
    var dock=document.querySelector('.report-utility-dock'); if(!dock)return;
    var search=dock.querySelector('.report-search-trigger'), print=dock.querySelector('.print-report-btn');
    if(search&&print&&search.compareDocumentPosition(print)&Node.DOCUMENT_POSITION_PRECEDING){dock.insertBefore(search,print);} 
  }
  function apply(){cleanForceClasses(document);bindFutureTabs();refineReadingIndex();classifySurfaces();moveUtilityOrder();}
  ready(function(){apply();setTimeout(apply,100);setTimeout(apply,800);setTimeout(apply,1800);});
  if(window.MutationObserver){
    new MutationObserver(function(records){
      var touched=false;
      records.forEach(function(r){if(r.addedNodes&&r.addedNodes.length)touched=true;});
      if(touched)setTimeout(apply,40);
    }).observe(document.documentElement,{childList:true,subtree:true});
  }
})();
</script>



