<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;margin-top:8px">
<!-- Pillar 1 -->
<div style="background:var(--cream);border:1px solid var(--bdr);border-top:3px solid var(--cr);padding:22px;border-radius:3px">
