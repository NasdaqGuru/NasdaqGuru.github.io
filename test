<script id="uaad-harvard-crimson-executive-blueprint-theme-v10-script">
(function(){
  function ready(fn){document.readyState==='loading'?document.addEventListener('DOMContentLoaded',fn):fn();}
  function applyTheme(){
    document.body && document.body.classList.add('uaad-theme-blueprint');
    document.documentElement.style.setProperty('--cr','#A41034','important');
    document.documentElement.style.setProperty('--gold','#C69214','important');
    document.documentElement.style.setProperty('--ink','#0B1020','important');
    document.querySelectorAll('.masthead, .proposal-hub, #s-resilience .ra-opening-strip, #s-resilience .ra-synthesis, #s-ecosystem .ise-arch-band').forEach(function(el){
      el.setAttribute('data-theme','harvard-crimson-executive-blueprint');
    });
  }
  ready(function(){applyTheme();setTimeout(applyTheme,100);setTimeout(applyTheme,900);});
  if(window.MutationObserver){
    new MutationObserver(function(){setTimeout(applyTheme,50);}).observe(document.documentElement,{childList:true,subtree:true});
  }
})();
</script>

