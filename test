function expandChart(srcId,title){
  if(!window.Chart){return;}
  if(!CC[srcId]) syncSourceChart(srcId);
  const src=CC[srcId];
  if(!src){
    setTimeout(()=>{if(CC[srcId])expandChart(srcId,title);},350);
    return;
  }
  const modal=document.getElementById('chartModal');
  const titleEl=document.getElementById('cmTitle');
  const detailEl=document.getElementById('cmDetail');
  titleEl.textContent=title||srcId;
  detailEl.innerHTML=CHART_DETAILS[srcId]||`<h4>Executive Reading</h4><p>This view expands the working chart for closer discussion. Values are used for portfolio demonstration unless otherwise noted in the surrounding report.</p>`;
  modal.classList.add('open');
  setTimeout(()=>{
    if(expC){try{expC.destroy();}catch(e){}expC=null;}
    try{
      const oldCanvas=document.getElementById('expandedChartCanvas');
      const fresh=oldCanvas.cloneNode(false);
      oldCanvas.parentNode.replaceChild(fresh,oldCanvas);
      const cfg={
        type:src.config.type,
        data:cloneChartConfig(src.config.data||src.data),
        options:cloneChartConfig(src.config.options||{})
      };
      cfg.options.maintainAspectRatio=false;
      cfg.options.responsive=true;
      cfg.options.animation=false;
      expC=new Chart(fresh,cfg);
    }catch(e){console.warn('expanded chart err',srcId,e);}
  },100);
}
document.addEventListener('keydown',e=>{
  if(e.key==='Escape'){
    closeModal();
    document.getElementById('chartModal').classList.remove('open');
    document.getElementById('discModal').classList.remove('open');
    closeReviewMap();
  }
});

function openDisclaimer(e){
  const modal=document.getElementById('discModal');
  const toggle=document.getElementById('discToggle');
  if(toggle) toggle.checked=true;
  if(modal) modal.classList.add('open');
}
function closeDisclaimer(){
  const modal=document.getElementById('discModal');
  const toggle=document.getElementById('discToggle');
  if(toggle) toggle.checked=false;
  if(modal) modal.classList.remove('open');
}
function openReviewMap(){
  const modal=document.getElementById('reviewMapModal');
  if(modal) modal.classList.add('open');
}
function closeReviewMap(){
  const modal=document.getElementById('reviewMapModal');
  if(modal) modal.classList.remove('open');
}
document.addEventListener('click',e=>{
  const link=e.target.closest?.('[data-disclaimer-link]');
  if(!link) return;
  const modal=document.getElementById('discModal');
  if(modal) modal.classList.add('open');
  if(location.hash!=='#discModal') history.replaceState(null,'','#discModal');
},true);
document.addEventListener('copy',e=>{
  const selected=window.getSelection ? window.getSelection().toString() : '';
  if(!selected) return;
  e.preventDefault();
  e.clipboardData.setData('text/plain',`${selected}\n\nCopyright © 2026 Narissara Khomkhai. All rights reserved. This strategic blueprint may not be copied, redistributed, reused, or adapted without written permission.`);
});

