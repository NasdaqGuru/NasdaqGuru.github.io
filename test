<script id="business-report-neutral-contrast-audit">
(function(){
  function parseRGB(value){
    if(!value || value === 'transparent') return null;
    const m = value.match(/rgba?\((\d+),\s*(\d+),\s*(\d+)(?:,\s*([\d.]+))?\)/i);
    if(!m) return null;
    const a = m[4] === undefined ? 1 : parseFloat(m[4]);
    if(a < 0.2) return null;
    return [parseInt(m[1],10), parseInt(m[2],10), parseInt(m[3],10)];
  }
  function lum(rgb){
    const v = rgb.map(c => {
      c /= 255;
      return c <= 0.03928 ? c/12.92 : Math.pow((c+0.055)/1.055,2.4);
    });
    return 0.2126*v[0] + 0.7152*v[1] + 0.0722*v[2];
  }
  function contrast(a,b){
    const L1 = lum(a), L2 = lum(b);
    return (Math.max(L1,L2)+0.05)/(Math.min(L1,L2)+0.05);
  }
  function saturation(rgb){
    const r=rgb[0]/255,g=rgb[1]/255,b=rgb[2]/255;
    const max=Math.max(r,g,b), min=Math.min(r,g,b);
    if(max===min) return 0;
    const l=(max+min)/2;
    return l>0.5 ? (max-min)/(2-max-min) : (max-min)/(max+min);
  }
  function closestBg(el){
    let cur=el;
    while(cur && cur.nodeType===1){
      const bg=parseRGB(getComputedStyle(cur).backgroundColor);
      if(bg) return bg;
      cur=cur.parentElement;
    }
    return [245,246,248];
  }
  function hasOwnText(el){
    for(const n of el.childNodes){
      if(n.nodeType===3 && n.nodeValue.trim()) return true;
    }
    return false;
  }
  function apply(){
    const navy='#0F2437', text='#111827', muted='#4B5563', surface='#FFFFFF', pale='#F1F3F5', line='#D6DAE0';
    const headerRegex=/(header|hero|masthead|cap|bar|titlebar|synthesis|opening|hub|modal-hdr|complete-head|review-map-hdr|disc-modal-hdr)/i;
    const surfaceRegex=/(card|tile|panel|module|callout|kpi|metric|stat|table|stage|step|node|badge|chip|pill|tag|tab)/i;

    document.querySelectorAll('*').forEach(el=>{
      const cs=getComputedStyle(el);
      const className=(el.className||'').toString();
      const id=(el.id||'').toString();
      const name=className+' '+id;
      const bg=parseRGB(cs.backgroundColor);
      const color=parseRGB(cs.color);
      if(!bg) return;

      // De-saturate highly colored non-semantic surfaces into business neutrals.
      const sat=saturation(bg);
      const l=lum(bg);
      const isHeader=headerRegex.test(name);
      const isSurface=surfaceRegex.test(name);
      const isSemantic=/(success|green|stable|warning|warn|amber|risk|critical|danger|red|error|info|blue)/i.test(name);

      if(isHeader || l < 0.18){
        el.style.backgroundColor=navy;
        el.style.backgroundImage='none';
        el.style.color='#FFFFFF';
        el.style.borderColor='#31465A';
      } else if(isSurface && sat > 0.18 && !isSemantic){
        el.style.backgroundColor = l > 0.82 ? pale : surface;
        el.style.backgroundImage='none';
        el.style.color=text;
        el.style.borderColor=line;
      }

      const currentBg=closestBg(el);
      const currentColor=parseRGB(getComputedStyle(el).color);
      if(currentColor && (hasOwnText(el) || ['TD','TH','BUTTON','A','SPAN','P','LI','H1','H2','H3','H4','H5','STRONG','B'].includes(el.tagName))){
        if(contrast(currentBg,currentColor) < 4.5){
          el.style.color = lum(currentBg) < 0.45 ? '#FFFFFF' : text;
        }
      }
    });

    // Ensure active tabs/buttons stay readable after inline cleanup.
    document.querySelectorAll('.active,[aria-selected="true"]').forEach(el=>{
      const name=((el.className||'')+' '+(el.getAttribute('role')||'')).toString();
      if(/tab|nav|button|item/i.test(name)){
        el.style.backgroundColor=navy;
        el.style.color='#FFFFFF';
        el.style.borderColor=navy;
        el.querySelectorAll('*').forEach(ch=>ch.style.color='#FFFFFF');
      }
    });
  }
  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded',()=>{apply(); setTimeout(apply,250); setTimeout(apply,1000);});
  } else {
    apply(); setTimeout(apply,250); setTimeout(apply,1000);
  }
})();
</script>


<script id="no-dark-background-script">
(function(){
  const LIGHT = '#ffffff';
  const SOFT = '#f8fafc';
  const TEXT = '#111827';
  const MUTED = '#334155';
  const BORDER = '#cbd5e1';
  const BLUE_SOFT = '#eaf2fb';

  function parseRgb(value){
    if(!value) return null;
    value = value.trim().toLowerCase();
    if(value === 'transparent' || value === 'rgba(0, 0, 0, 0)') return null;
    const m = value.match(/rgba?\(([^)]+)\)/);
    if(m){
      const parts = m[1].split(',').map(s => parseFloat(s.trim()));
      if(parts.length >= 3) return {r:parts[0], g:parts[1], b:parts[2], a:parts[3] ?? 1};
    }
    if(value[0] === '#'){
      let h = value.slice(1);
      if(h.length === 3) h = h.split('').map(c=>c+c).join('');
      if(h.length >= 6){
        return {r:parseInt(h.slice(0,2),16), g:parseInt(h.slice(2,4),16), b:parseInt(h.slice(4,6),16), a:1};
      }
    }
    return null;
  }
  function luminance(rgb){
    const srgb = [rgb.r,rgb.g,rgb.b].map(v=>{
      v = v/255;
      return v <= 0.03928 ? v/12.92 : Math.pow((v+0.055)/1.055,2.4);
    });
    return 0.2126*srgb[0]+0.7152*srgb[1]+0.0722*srgb[2];
  }
  function isDark(color){
    const rgb = parseRgb(color);
    if(!rgb || rgb.a === 0) return false;
    return luminance(rgb) < 0.32;
  }
  function isVeryLight(color){
    const rgb = parseRgb(color);
    if(!rgb || rgb.a === 0) return false;
    return luminance(rgb) > 0.86;
  }
  function fix(){
    const all = Array.from(document.querySelectorAll('body *'));
    for(const el of all){
      const cs = getComputedStyle(el);
      const bg = cs.backgroundColor;
      const fg = cs.color;
      if(isDark(bg)){
        el.style.setProperty('background', LIGHT, 'important');
        el.style.setProperty('background-image', 'none', 'important');
        el.style.setProperty('color', TEXT, 'important');
        el.style.setProperty('border-color', BORDER, 'important');
      } else if(isVeryLight(bg) && isVeryLight(fg)){
        el.style.setProperty('color', TEXT, 'important');
      } else if(isDark(fg) === false && isVeryLight(bg)){
        // keep muted non-white text readable on light surfaces
        const rgb = parseRgb(fg);
        if(rgb && luminance(rgb) > 0.68) el.style.setProperty('color', MUTED, 'important');
      }
    }
    const headers = document.querySelectorAll('.section-header,.section-head,.card-header,.proposal-hub-head,.modal-header,.hero-strip,.proposal-hub,[class*="header"],[class*="head"],[class*="bar"],[class*="cap"]');
    headers.forEach(el=>{
      const cs = getComputedStyle(el);
      if(isDark(cs.backgroundColor)){
        el.style.setProperty('background', BLUE_SOFT, 'important');
        el.style.setProperty('background-image','none','important');
        el.style.setProperty('color', TEXT, 'important');
      }
    });
  }
  if(document.readyState === 'loading') document.addEventListener('DOMContentLoaded', ()=>{fix(); setTimeout(fix,200); setTimeout(fix,1000);});
  else {fix(); setTimeout(fix,200); setTimeout(fix,1000);}
})();
</script>


<script id="no-dark-runtime-contrast-cleanup">
(function(){
  function parseRgb(value){
    const match = /rgba?\((\d+),\s*(\d+),\s*(\d+)(?:,\s*([\d.]+))?\)/.exec(value || '');
    if(!match) return null;
    return {r:+match[1], g:+match[2], b:+match[3], a:match[4] === undefined ? 1 : +match[4]};
  }
  function luminance(c){
    const vals = [c.r,c.g,c.b].map(v => {
      v /= 255;
      return v <= 0.03928 ? v / 12.92 : Math.pow((v + 0.055) / 1.055, 2.4);
    });
    return 0.2126 * vals[0] + 0.7152 * vals[1] + 0.0722 * vals[2];
  }
  function cleanup(){
    const lightSurface = '#ffffff';
    const lightAlt = '#f8fafc';
    const text = '#111827';
    const border = '#cbd5e1';
    document.querySelectorAll('body *').forEach(el => {
      if(el.matches('canvas,svg,img,video,path,rect,circle,line,polyline,polygon')) return;
      const style = getComputedStyle(el);
      const bg = parseRgb(style.backgroundColor);
      if(bg && bg.a > 0.1 && luminance(bg) < 0.22){
        el.style.setProperty('background', lightSurface, 'important');
        el.style.setProperty('background-image', 'none', 'important');
        el.style.setProperty('color', text, 'important');
        if(style.borderTopStyle !== 'none') el.style.setProperty('border-color', border, 'important');
      }
      const fg = parseRgb(style.color);
      const newBg = parseRgb(getComputedStyle(el).backgroundColor);
      if(fg && newBg && fg.a > 0.1 && newBg.a > 0.1){
        const diff = Math.abs(luminance(fg) - luminance(newBg));
        if(diff < 0.18){
          el.style.setProperty('color', text, 'important');
          if(luminance(newBg) < 0.35){
            el.style.setProperty('background', lightAlt, 'important');
          }
        }
      }
    });
  }
  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', cleanup);
  } else {
    cleanup();
  }
  window.addEventListener('load', cleanup);
})();
</script>



