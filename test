<script id="execpath-contrast-final-js">
(function(){
  var STORAGE='avp_masterplan_reading_path_v2';
  var START=STORAGE+'_startedAt';
  var LAST=STORAGE+'_last_section';
  function ready(fn){document.readyState==='loading'?document.addEventListener('DOMContentLoaded',fn):fn();}
  function current(){var a=document.querySelector('.section-panel.active');return a?a.id:'s-opportunity';}
  function openSection(id){if(!id) return; try{ if(typeof activateTab==='function') activateTab(id,document.querySelector('[data-tab="'+id+'"]')); }catch(e){} }
  function resetReadState(){try{localStorage.removeItem(STORAGE);sessionStorage.removeItem(STORAGE+'_complete');}catch(e){}; if(typeof window.resetExecutivePath==='function'){try{window.resetExecutivePath();}catch(e){}}}
  // Reset reading clock each time the page opens, but keep last section for Resume.
  try{localStorage.setItem(START,String(Date.now()));sessionStorage.removeItem(STORAGE+'_complete');}catch(e){}
  ready(function(){
    // Make the reading-order popup simple and clean.
    document.querySelectorAll('.review-map-actions button').forEach(function(b){ if(/Let/i.test(b.textContent)||/Begin/i.test(b.textContent)){ b.textContent="Let's Start"; } });
    // Store last active section and enable resume.
    try{localStorage.setItem(LAST,current());}catch(e){}
    var resume=document.getElementById('resumeLastVisit');
    if(resume){resume.addEventListener('click',function(){var id=null;try{id=localStorage.getItem(LAST);}catch(e){} openSection(id||'s-opportunity');});}
    var resetBottom=document.getElementById('resetExecutivePathBottom');
    if(resetBottom){resetBottom.addEventListener('click',function(){resetReadState();});}
    // Completion close resets visited read path as requested.
    var close=document.getElementById('avpCompleteCloseReset');
    if(close){close.addEventListener('click',function(){resetReadState();});}
    // If user clicks the completion overlay close area, only close; button handles reset.
    // Wrap activateTab to remember the last section for the Resume button.
    var old=window.activateTab;
    if(typeof old==='function'&&!old.__resumeWrapped){
      var wrapped=function(id){var r=old.apply(this,arguments);try{localStorage.setItem(LAST,id||current());}catch(e){}return r;};
      wrapped.__resumeWrapped=true; window.activateTab=wrapped;
    }
    // Re-apply table header contrast after dynamic modal content opens.
    document.addEventListener('click',function(){setTimeout(function(){document.querySelectorAll('#infoModal table thead th,#chartModal table thead th,.modal table thead th').forEach(function(th){th.style.setProperty('background','#A41034','important');th.style.setProperty('color','#fff','important');});},80);},true);
