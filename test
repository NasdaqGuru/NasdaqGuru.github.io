(function(){
  function ready(fn){document.readyState==='loading'?document.addEventListener('DOMContentLoaded',fn):fn();}
  function rgb(c){var m=(c||'').match(/rgba?\(([^)]+)\)/);if(!m)return null;var p=m[1].split(',').map(function(x){return parseFloat(x)});return {r:p[0]||0,g:p[1]||0,b:p[2]||0,a:p.length>3?p[3]:1};}
  function luminance(x){if(!x||x.a===0)return 255;return 0.2126*x.r+0.7152*x.g+0.0722*x.b;}
  function effectiveBg(el){var cur=el;while(cur&&cur.nodeType===1){var b=rgb(getComputedStyle(cur).backgroundColor);if(b&&b.a>.12)return b;cur=cur.parentElement;}return {r:255,g:255,b:255,a:1};}
  function cleanForcedContrast(){
    document.querySelectorAll('.hks-force-light').forEach(function(el){
      var l=luminance(effectiveBg(el));
      if(l>145 || el.closest('.card,.callout,.accordion-body,.infographic-card,.comp-card,.ai-impact-card,.res52-panel,.res52-card,.res52-metric,.report-search-modal,.link-rec-modal,.smarter-table,.search-hit,.reader-note,.sb-suite')){
