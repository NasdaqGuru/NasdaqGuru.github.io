.unity-kpi b{display:block!important;font-family:var(--display,Georgia,serif)!important;font-size:1.35rem!important;line-height:1!important;color:var(--unity-blue)!important;margin-bottom:5px!important;}
.unity-kpi span{display:block!important;font-family:var(--mono,monospace)!important;font-size:.56rem!important;letter-spacing:.08em!important;text-transform:uppercase!important;color:var(--unity-muted)!important;line-height:1.25!important;}
.unity-adhd-strip{border-top:1px solid var(--unity-line)!important;background:#f8fafc!important;padding:14px 24px!important;display:grid!important;grid-template-columns:140px 1fr!important;gap:14px!important;align-items:start!important;}
.unity-adhd-strip b{font-family:var(--mono,monospace)!important;font-size:.62rem!important;letter-spacing:.12em!important;text-transform:uppercase!important;color:var(--unity-blue)!important;}
.unity-adhd-strip p{margin:0!important;color:var(--unity-text)!important;font-size:.86rem!important;line-height:1.55!important;}
.unity-chip{display:inline-flex!important;align-items:center!important;border:1px solid #c8d8e8!important;background:#fff!important;color:var(--unity-blue)!important;border-radius:999px!important;padding:3px 8px!important;font-size:.72rem!important;font-weight:800!important;margin:2px 4px 2px 0!important;white-space:nowrap!important;}
/* Sidebar/nav rebuilt */
#sidebar{background:#fff!important;border:1px solid var(--unity-line)!important;color:var(--unity-text)!important;}
#sidebar .sb-brand{background:#fff!important;border:1px solid var(--unity-line)!important;color:var(--unity-text)!important;}
#sidebar .sb-title,#sidebar .sb-inst,#sidebar .sb-sub{color:var(--unity-ink)!important;}
.unity-nav{display:grid!important;gap:12px!important;margin-top:14px!important;}
.unity-nav-group{border:1px solid var(--unity-line)!important;border-radius:14px!important;background:#fff!important;overflow:hidden!important;}
.unity-nav-title{background:#f8fafc!important;border-bottom:1px solid var(--unity-line)!important;padding:10px 12px!important;font-family:var(--mono,monospace)!important;font-size:.57rem!important;letter-spacing:.12em!important;text-transform:uppercase!important;color:var(--unity-muted)!important;font-weight:900!important;}
.unity-nav .nav-item{width:100%!important;display:grid!important;grid-template-columns:34px 1fr!important;gap:8px!important;align-items:start!important;text-align:left!important;background:#fff!important;color:var(--unity-text)!important;border:0!important;border-bottom:1px solid #eef2f7!important;border-left:4px solid transparent!important;border-radius:0!important;padding:10px 10px!important;font-family:var(--sans,Arial,sans-serif)!important;font-size:.78rem!important;line-height:1.25!important;box-shadow:none!important;}
.unity-nav .nav-item:last-child{border-bottom:0!important;}
.unity-nav .nav-item:hover{background:#f8fafc!important;color:var(--unity-blue)!important;border-left-color:#bdd2e5!important;}
.unity-nav .nav-item.active{background:#eef6ff!important;color:var(--unity-blue)!important;border-left-color:var(--unity-blue)!important;font-weight:900!important;box-shadow:none!important;}
.unity-nav .nav-item-num{color:var(--unity-blue)!important;font-family:var(--mono,monospace)!important;font-size:.65rem!important;font-weight:900!important;line-height:1.25!important;}
.unity-nav .nav-item .mini{display:block!important;color:var(--unity-muted)!important;font-size:.68rem!important;font-weight:500!important;margin-top:2px!important;}
/* Reading track */
.sb-path{background:#fff!important;border:1px solid var(--unity-line)!important;border-radius:16px!important;box-shadow:0 8px 20px rgba(15,23,42,.04)!important;color:var(--unity-text)!important;}
.sb-path-title{color:var(--unity-ink)!important;font-family:var(--display,Georgia,serif)!important;font-size:1.08rem!important;}
.sb-path-kicker{color:var(--unity-blue)!important;}
.sb-path-track{background:#e5edf5!important;border-radius:999px!important;height:9px!important;overflow:hidden!important;}
.sb-path-fill{background:linear-gradient(90deg,var(--unity-blue),#6aa2c8)!important;height:100%!important;}
.sb-path-actions,.sb-path-footer-actions{display:grid!important;grid-template-columns:1fr!important;gap:8px!important;}
.sb-path-actions button,.sb-path-footer-actions button{background:#fff!important;border:1px solid var(--unity-line)!important;color:var(--unity-blue)!important;border-radius:10px!important;padding:9px 10px!important;font-weight:900!important;}
.sb-path-actions button:first-child{background:var(--unity-blue)!important;color:#fff!important;border-color:var(--unity-blue)!important;}
.sb-reset-check{display:none!important;}
.sb-path-sync-note{display:none!important;}
.sb-path-list{display:grid!important;gap:10px!important;max-height:none!important;overflow:visible!important;}
.unity-track-group{border:1px solid var(--unity-line)!important;border-radius:12px!important;background:#fff!important;overflow:hidden!important;}
.unity-track-title{background:#f8fafc!important;padding:8px 10px!important;border-bottom:1px solid var(--unity-line)!important;color:var(--unity-muted)!important;font-family:var(--mono,monospace)!important;font-size:.55rem!important;letter-spacing:.1em!important;text-transform:uppercase!important;font-weight:900!important;}
.unity-track-item{width:100%!important;display:grid!important;grid-template-columns:22px 1fr!important;gap:8px!important;align-items:start!important;background:#fff!important;border:0!important;border-bottom:1px solid #eef2f7!important;text-align:left!important;padding:9px 10px!important;color:var(--unity-text)!important;cursor:pointer!important;}
.unity-track-item:last-child{border-bottom:0!important;}
.unity-track-item:hover{background:#f8fafc!important;}
.unity-track-item.is-active{background:#eef6ff!important;color:var(--unity-blue)!important;}
.unity-track-dot{width:18px!important;height:18px!important;border:2px solid #cbd5e1!important;border-radius:999px!important;margin-top:1px!important;display:block!important;}
.unity-track-item.is-read .unity-track-dot{background:var(--unity-green)!important;border-color:var(--unity-green)!important;box-shadow:inset 0 0 0 4px #fff!important;}
.unity-track-label{font-size:.75rem!important;line-height:1.25!important;font-weight:800!important;color:inherit!important;}
.unity-track-label span{display:block!important;font-size:.66rem!important;font-weight:500!important;color:var(--unity-muted)!important;margin-top:2px!important;}
/* Review map */
.review-map,.avp-complete-modal{background:#fff!important;color:var(--unity-text)!important;border:1px solid var(--unity-line)!important;box-shadow:var(--unity-shadow)!important;}
.review-map-hdr,.avp-complete-head,.disc-modal-hdr,.link-rec-head{background:#f8fafc!important;color:var(--unity-ink)!important;border-bottom:1px solid var(--unity-line)!important;}
.review-map-hdr *,.avp-complete-head *,.disc-modal-hdr *,.link-rec-head *{color:var(--unity-ink)!important;}
.review-path{display:grid!important;grid-template-columns:repeat(2,minmax(0,1fr))!important;gap:12px!important;}
.review-step{background:#fff!important;border:1px solid var(--unity-line)!important;border-left:4px solid var(--unity-blue)!important;border-radius:12px!important;padding:13px!important;color:var(--unity-text)!important;}
.review-step b{color:var(--unity-blue)!important;}.review-step strong{color:var(--unity-ink)!important;}.review-step span{color:var(--unity-text)!important;}
.review-map-actions{display:flex!important;gap:8px!important;flex-wrap:wrap!important;}
.review-map-actions button,.review-map-actions a{background:#fff!important;color:var(--unity-blue)!important;border:1px solid var(--unity-line)!important;border-radius:999px!important;padding:9px 13px!important;font-weight:900!important;text-decoration:none!important;}
.review-map-actions button{background:var(--unity-blue)!important;color:#fff!important;border-color:var(--unity-blue)!important;}
/* Deduplication: old grouped side-nav if still present becomes hidden once unity nav exists. */
#sidebar.has-unity-nav > .nav-group{display:none!important;}
#mobileNavItems .mobile-group-title{font-family:var(--mono,monospace)!important;font-size:.58rem!important;letter-spacing:.12em!important;text-transform:uppercase!important;color:var(--unity-muted)!important;background:#f8fafc!important;padding:10px 12px!important;border-top:1px solid var(--unity-line)!important;}
#mobileNavItems .nav-item{background:#fff!important;color:var(--unity-text)!important;border:0!important;border-bottom:1px solid #eef2f7!important;border-left:4px solid transparent!important;border-radius:0!important;box-shadow:none!important;}
#mobileNavItems .nav-item.active{background:#eef6ff!important;color:var(--unity-blue)!important;border-left-color:var(--unity-blue)!important;}
@media(max-width:1100px){.unity-priority-grid{grid-template-columns:repeat(2,minmax(0,1fr))!important}.unity-kpi-row{grid-template-columns:repeat(3,minmax(0,1fr))!important}.unity-start-head{grid-template-columns:1fr!important}.unity-start-actions{justify-content:flex-start!important}}
@media(max-width:720px){.unity-priority-grid,.unity-kpi-row{grid-template-columns:1fr!important}.unity-adhd-strip{grid-template-columns:1fr!important}.review-path{grid-template-columns:1fr!important}.unity-start{border-radius:12px!important}.unity-start-head,.unity-priority-grid,.unity-kpi-row,.unity-adhd-strip{padding-left:16px!important;padding-right:16px!important}}
@media print{.unity-start-actions,.unity-nav,.sb-path{display:none!important}.unity-start{box-shadow:none!important}}
</style>
<script id="global-unity-adhd-script">
(function(){
  var SECTIONS = [
    {id:'s-opportunity',num:'1.1',label:'Strategic Opportunity',micro:'Why this matters now',group:'Start Here'},
    {id:'s-overview',num:'1.2',label:'Proposed Solution',micro:'The blueprint in one view',group:'Start Here'},
    {id:'s-transformation-outline',num:'1.3',label:'Impact + Governance',micro:'Ownership, budget, KPIs',group:'Start Here'},
    {id:'s-orgchart',num:'2.0',label:'Org Architecture',micro:'How the work is staffed',group:'Operating Model'},
    {id:'s-ai-pillars',num:'2.1',label:'AI Adoption Pillars',micro:'Principles for adoption',group:'Operating Model'},
    {id:'s-strategy',num:'2.2',label:'SET Strategy',micro:'Segment, Engage, Transform',group:'Operating Model'},
    {id:'s-matrix',num:'2.3',label:'Matrix + Schools',micro:'Autonomy with coordination',group:'Operating Model'},
    {id:'s-ecosystem',num:'2.4',label:'Solutions Ecosystem',micro:'Service spine and idea flow',group:'Operating Model'},
    {id:'s-datamodels',num:'3.1',label:'Data Readiness',micro:'Master ID and school sync',group:'Data + Automation'},
    {id:'s-automation',num:'3.2',label:'Change Protocol',micro:'Controls and adoption',group:'Data + Automation'},
    {id:'s-workflows',num:'3.3',label:'Core AI Workflows',micro:'What automation handles',group:'Data + Automation'},
    {id:'s-dashboards',num:'3.4',label:'Command Dashboards',micro:'Leadership signal layer',group:'Data + Automation'},
    {id:'s-pipeline',num:'4.1',label:'Gift Pipeline',micro:'School/program opportunity',group:'Campaign Engine'},
    {id:'s-lifecycle',num:'4.2',label:'Lifecycle + Timeline',micro:'Past, present, future',group:'Campaign Engine'},
    {id:'s-roadmap',num:'4.3',label:'Implementation Roadmap',micro:'Sequence and investment',group:'Campaign Engine'},
    {id:'s-future',num:'4.4',label:'Future Vision',micro:'What comes next',group:'Campaign Engine'},
    {id:'s-smarter',num:'4.5',label:'SMARTER Goals',micro:'Measurement and logic',group:'Campaign Engine'},
    {id:'s-resilience',num:'5.1',label:'Resilience Architecture',micro:'Risk, trust, campaign readiness',group:'Governance + Evidence'},
    {id:'s-report-system',num:'5.2',label:'Report System Map',micro:'Evidence and contradictions',group:'Governance + Evidence'},
    {id:'s-redesign-services',num:'5.3',label:'Redesign Service Framework',micro:'Reconstruction standards',group:'Governance + Evidence'},
    {id:'s-appendix',num:'5.4',label:'Appendix + References',micro:'Sources and companion work',group:'Governance + Evidence'}
  ];
  var GROUPS=['Start Here','Operating Model','Data + Automation','Campaign Engine','Governance + Evidence'];
  var STORAGE='uaad_unity_read_v1';
  var START=STORAGE+'_start';
  var LAST=STORAGE+'_last';
  var byId={}; SECTIONS.forEach(function(s){byId[s.id]=s;});
  function $(s,root){return (root||document).querySelector(s);}
  function $all(s,root){return Array.prototype.slice.call((root||document).querySelectorAll(s));}
  function ready(fn){document.readyState==='loading'?document.addEventListener('DOMContentLoaded',fn):fn();}
  function esc(s){return String(s||'').replace(/[&<>"']/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[c];});}
  function state(){try{return JSON.parse(localStorage.getItem(STORAGE)||'{}')||{};}catch(e){return {};}}
  function save(st){try{localStorage.setItem(STORAGE,JSON.stringify(st||{}));}catch(e){}}
  function current(){var active=$('.section-panel.active');return active?active.id:'s-opportunity';}
  function label(id){var s=byId[id];return s?s.num+' '+s.label:id;}
  function countRead(){var st=state();return SECTIONS.filter(function(s){return st[s.id];}).length;}
  function elapsed(){var start=0;try{start=Number(localStorage.getItem(START)||Date.now());}catch(e){start=Date.now();}var m=Math.max(0,Math.round((Date.now()-start)/60000));return m<1?'Under 1 min':m+' min';}
  function openSection(id){
    if(!byId[id]) id='s-opportunity';
    try{localStorage.setItem(LAST,id);}catch(e){}
    if(typeof window.activateTab==='function'){
      try{window.activateTab(id,$('[data-tab="'+id+'"]'));}catch(e){}
    } else {
      $all('.section-panel').forEach(function(p){var on=p.id===id;p.classList.toggle('active',on);p.toggleAttribute('hidden',!on);});
    }
    $all('[data-tab]').forEach(function(b){b.classList.toggle('active',b.getAttribute('data-tab')===id);});
    var mt=$('#mobileNavTitle'); if(mt) mt.textContent=label(id);
    refresh();
  }
  function markRead(id){var st=state();st[id||current()]=true;save(st);refresh();}
  function reset(){save({});try{localStorage.setItem(START,String(Date.now()));sessionStorage.removeItem('avp_masterplan_reading_path_v2_complete');}catch(e){}refresh();}
  function nextUnread(){var st=state();var nxt=SECTIONS.find(function(s){return !st[s.id];});openSection(nxt?nxt.id:'s-opportunity');}
  function resume(){var id=null;try{id=localStorage.getItem(LAST);}catch(e){}openSection(id||current()||'s-opportunity');}
  function groupedHtml(kind){
    return GROUPS.map(function(g){
      var items=SECTIONS.filter(function(s){return s.group===g;});
      if(kind==='nav'){
        return '<div class="unity-nav-group"><div class="unity-nav-title">'+esc(g)+'</div>'+items.map(function(s){return '<button class="nav-item" type="button" data-tab="'+s.id+'"><span class="nav-item-num">'+s.num+'</span><span>'+esc(s.label)+'<span class="mini">'+esc(s.micro)+'</span></span></button>';}).join('')+'</div>';
      }
      return '<div class="unity-track-group"><div class="unity-track-title">'+esc(g)+'</div>'+items.map(function(s){return '<button class="unity-track-item" type="button" data-target="'+s.id+'"><span class="unity-track-dot"></span><span class="unity-track-label">'+s.num+' · '+esc(s.label)+'<span>'+esc(s.micro)+'</span></span></button>';}).join('')+'</div>';
    }).join('');
  }
  function buildFirstImpression(){
    var main=$('#mainContent'); if(!main || $('#unityStart')) return;
    var html='<section class="unity-start no-print" id="unityStart" aria-label="Executive first impression">'+
      '<div class="unity-start-head"><div><div class="unity-kicker">Start here · priority-first decision brief</div><h2>Read the masterplan by <em>decision value</em>, not page order.</h2><p class="unity-start-dek">This reconstruction makes the report easier to scan: first the executive answer, then the dashboard, then the operating model, then the evidence and release standards. Each track is short enough to keep momentum without losing strategic rigor.</p></div><div class="unity-start-actions"><button class="unity-action primary" type="button" data-unity-open="s-opportunity">Start review</button><button class="unity-action" type="button" data-unity-open="s-dashboards">Open dashboard</button><button class="unity-action" type="button" data-unity-open="s-redesign-services">See reconstruction steps</button></div></div>'+
      '<div class="unity-priority-grid">'+
      '<div class="unity-priority"><b>Priority 1</b><strong>Executive answer first</strong><span>Harvard needs a governed advancement intelligence spine: shared identity, trusted dashboards, AI workflow support, and campaign-ready risk controls.</span></div>'+
      '<div class="unity-priority"><b>Priority 2</b><strong>Dashboard before details</strong><span>Leaders should see the current signal layer first: pipeline movement, gift velocity, adoption, risk, and readiness.</span></div>'+
      '<div class="unity-priority"><b>Priority 3</b><strong>Rebuild as a service system</strong><span>Diagnose → architect → redesign → govern → verify. The report now follows that service logic instead of accumulating disconnected sections.</span></div>'+
      '<div class="unity-priority"><b>Priority 4</b><strong>Evidence last, not lost</strong><span>Appendix, framework, and companion reports remain available, but they support the decision path rather than interrupt it.</span></div>'+
      '</div>'+
      '<div class="unity-kpi-row">'+
      '<div class="unity-kpi"><b>21</b><span>Unified sections</span></div><div class="unity-kpi"><b>5</b><span>Reading tracks</span></div><div class="unity-kpi"><b>$1.42B</b><span>FY26 signal</span></div><div class="unity-kpi"><b>$2.1B</b><span>9-figure pipeline</span></div><div class="unity-kpi"><b>81%</b><span>AI adoption lens</span></div><div class="unity-kpi"><b>5</b><span>Rebuild steps</span></div>'+
      '</div>'+
      '<div class="unity-adhd-strip"><b>ADHD-friendly reading</b><p><span class="unity-chip">scan cards first</span><span class="unity-chip">use Next Unread</span><span class="unity-chip">mark each section</span><span class="unity-chip">dashboard before prose</span><span class="unity-chip">appendix only when needed</span><br/>The aim is lower cognitive load: visible progress, short labels, grouped sections, and one consistent path from urgency to proof.</p></div>'+
      '</section>';
    main.insertAdjacentHTML('afterbegin',html);
  }
  function buildNav(){
    var sidebar=$('#sidebar'); if(sidebar){
      var old=$('.unity-nav',sidebar); if(old) old.remove();
      sidebar.classList.add('has-unity-nav');
      sidebar.insertAdjacentHTML('beforeend','<div class="unity-nav" aria-label="Unified report index">'+groupedHtml('nav')+'</div>');
    }
    var mobile=$('#mobileNavItems'); if(mobile){
      mobile.innerHTML=GROUPS.map(function(g){var items=SECTIONS.filter(function(s){return s.group===g;});return '<div class="mobile-group-title">'+esc(g)+'</div>'+items.map(function(s){return '<button class="nav-item" type="button" data-tab="'+s.id+'"><span class="nav-item-num">'+s.num+'</span> '+esc(s.label)+'</button>';}).join('');}).join('');
    }
  }
  function buildTrack(){
    var list=$('.sb-path-list'); if(list) list.innerHTML=groupedHtml('track');
    var title=$('.sb-path-title'); if(title) title.textContent='Reading Track';
    var kicker=$('.sb-path-kicker'); if(kicker) kicker.textContent='Priority path';
    var complete=$('.avp-complete-stat b'); if(complete && /^\d+\/\d+/.test(complete.textContent.trim())) complete.textContent='21/21';
  }
  function buildReviewMap(){
    var body=$('.review-map-body'); if(!body) return;
    body.innerHTML='<div class="review-path">'+GROUPS.map(function(g,i){var items=SECTIONS.filter(function(s){return s.group===g;});return '<div class="review-step"><b>'+(i+1)+' · '+esc(g)+'</b><strong>'+esc(items[0].label)+' → '+esc(items[items.length-1].label)+'</strong><span>'+items.length+' sections · '+esc(items.map(function(s){return s.micro;}).slice(0,2).join(' · '))+'</span></div>';}).join('')+'</div><div class="review-map-actions"><button type="button" data-unity-open="s-opportunity">Start with highlights</button><a href="#s-dashboards" data-unity-open="s-dashboards">Open dashboard</a><a href="#s-redesign-services" data-unity-open="s-redesign-services">Open reconstruction steps</a><a href="#s-report-system" data-unity-open="s-report-system">Open evidence map</a></div>';
    var title=$('#reviewMapTitle'); if(title) title.textContent='Read the Proposal in Five Focused Tracks';
    var kicker=$('.review-map-kicker'); if(kicker) kicker.textContent='Executive Reading Track';
    var desc=$('.review-map-hdr p'); if(desc) desc.textContent='Start with the decision brief, then use the dashboard and reconstruction sequence before moving into detailed evidence.';
  }
  function bind(){
    document.addEventListener('click',function(e){
      var btn=e.target.closest('[data-unity-open]'); if(btn){e.preventDefault();var id=btn.getAttribute('data-unity-open');if(typeof window.closeReviewMap==='function')try{window.closeReviewMap();}catch(x){}openSection(id);return;}
      var nav=e.target.closest('.unity-nav .nav-item,#mobileNavItems .nav-item'); if(nav&&nav.getAttribute('data-tab')){e.preventDefault();openSection(nav.getAttribute('data-tab'));return;}
      var track=e.target.closest('.unity-track-item'); if(track){e.preventDefault();openSection(track.getAttribute('data-target'));return;}
    },true);
    var mark=$('#markCurrentRead'); if(mark) mark.onclick=function(){markRead(current());};
    var next=$('#nextUnreadSection'); if(next) next.onclick=nextUnread;
    var resetTop=$('#resetExecutivePath'); if(resetTop) resetTop.onclick=reset;
    var resetBottom=$('#resetExecutivePathBottom'); if(resetBottom) resetBottom.onclick=reset;
    var resumeBtn=$('#resumeLastVisit'); if(resumeBtn) resumeBtn.onclick=resume;
  }
  function refresh(){
    var cur=current();var st=state();var read=countRead();var pct=Math.round(read/SECTIONS.length*100);
    $all('[data-tab]').forEach(function(b){b.classList.toggle('active',b.getAttribute('data-tab')===cur);});
    $all('.unity-track-item').forEach(function(b){var id=b.getAttribute('data-target');b.classList.toggle('is-active',id===cur);b.classList.toggle('is-read',!!st[id]);});
    var fill=$('#sbPathFill'); if(fill) fill.style.width=pct+'%';
    var cnt=$('#sbPathCount'); if(cnt) cnt.textContent=read+' / '+SECTIONS.length+' read';
    var pctEl=$('#sbPathPct'); if(pctEl) pctEl.textContent=pct+'%';
    var time=$('#sbPathTime'); if(time) time.textContent='Reading time: '+elapsed();
    var mt=$('#readingTimeSpent'); if(mt) mt.textContent=elapsed();
    var mobile=$('#mobileNavTitle'); if(mobile) mobile.textContent=label(cur);
    try{localStorage.setItem(LAST,cur);}catch(e){}
  }
  function wrapActivate(){
    if(typeof window.activateTab==='function' && !window.activateTab.__unityWrapped){
      var old=window.activateTab;
      window.activateTab=function(id){var r=old.apply(this,arguments);setTimeout(function(){refresh();},20);return r;};
      window.activateTab.__unityWrapped=true;
    }
  }
  ready(function(){
    try{if(!localStorage.getItem(START)) localStorage.setItem(START,String(Date.now()));}catch(e){}
    buildFirstImpression();buildNav();buildTrack();buildReviewMap();bind();wrapActivate();refresh();
    setTimeout(function(){buildNav();buildTrack();refresh();},250);
    setInterval(refresh,30000);
    window.UAAD_UNIFIED_SECTIONS=SECTIONS;
    window.UAAD_UNITY_MARK_READ=function(){markRead(current());};
    window.UAAD_UNITY_RESET=reset;
  });
})();
</script>


<script id="clean-executive-redesign-v3-script">
(function(){
  function luminance(rgb){
    var m=(rgb||'').match(/rgba?\((\d+),\s*(\d+),\s*(\d+)/i);
    if(!m) return 255;
    return 0.2126*(+m[1])+0.7152*(+m[2])+0.0722*(+m[3]);
  }
  function cleanup(){
    document.body.classList.remove('uaad-theme-blueprint','uaad-theme-adoptive','theme-clean-exec');
    document.body.classList.add('clean-executive-report');

    // Remove empty decorative layers and forced dark inline backgrounds left by older theme generations.
