<script id="uaad-v9-requested-repair-script">
(function(){
  function ready(fn){document.readyState==='loading'?document.addEventListener('DOMContentLoaded',fn):fn();}
  function textOf(el){return (el&&el.textContent||'').replace(/\s+/g,' ').trim();}
  function findByText(selector, pattern){
    var re=pattern instanceof RegExp?pattern:new RegExp(pattern,'i');
    return Array.prototype.find.call(document.querySelectorAll(selector), function(el){return re.test(textOf(el));});
  }
  function closestDarkCard(el){
    if(!el)return null;
    return el.closest('div[style*="background:var(--ink)"]') || el.closest('div[style*="background: var(--ink)"]') || el.closest('.card') || el.parentElement;
  }
  function applyRequestedContrast(){
    // Black text on light backgrounds.
    var zero=findByText('#s-orgchart *', /Zero Formal Authority.*Maximum Strategic Influence/i);
    var zeroBox=closestDarkCard(zero); if(zeroBox)zeroBox.classList.add('uaad-v9-light-request');
    var nonneg=findByText('#s-ai-pillars *', /The Three Non-Negotiables/i);
    var nonnegBox=closestDarkCard(nonneg); if(nonnegBox)nonnegBox.classList.add('uaad-v9-light-request');
    var impl=findByText('#s-roadmap *, #s-future *, #s-smarter *', /Implementation Methodology/i) || findByText('body *', /^Implementation Methodology$/i);
    var implBox=closestDarkCard(impl); if(implBox)implBox.classList.add('uaad-v9-light-request');
    var advisor=findByText('#s-resilience *', /Indispensable Strategic Advisor Role/i) || findByText('body *', /Indispensable Strategic Advisor Role/i);
    var advBox=closestDarkCard(advisor); if(advBox)advBox.classList.add('uaad-v9-light-request');
    var dev=findByText('h1,h2,h3,div', /Development Team Operating Map/i);
    var devBox=dev ? (dev.closest('div[style*="margin-top"]') || dev.closest('.wrap') || dev.parentElement) : null;
    if(devBox)devBox.classList.add('uaad-v9-development-map');
    // White text request for sustainability section.
    var dsust=document.getElementById('dsust'); if(dsust)dsust.classList.add('uaad-v9-dark-request');
    // Keep 2.2 guaranteed sample first and visible.
    var sample=document.getElementById('uaad-sec22-report-sample-guaranteed');
    var sec=document.getElementById('s-matrix');
    if(sample&&sec){sample.style.display='block';sample.style.visibility='visible';sample.style.opacity='1';sample.removeAttribute('hidden');}
    // Unvisited Open action white.
    document.querySelectorAll('.unvisited-card span.action').forEach(function(el){el.style.setProperty('color','#fff','important');});
  }
  ready(function(){applyRequestedContrast();setTimeout(applyRequestedContrast,100);setTimeout(applyRequestedContrast,800);setTimeout(applyRequestedContrast,1800);});
  if(window.MutationObserver){
    new MutationObserver(function(){setTimeout(applyRequestedContrast,40);}).observe(document.documentElement,{childList:true,subtree:true});
  }
})();
</script>



