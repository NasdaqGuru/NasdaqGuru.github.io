<!DOCTYPE html>

<html lang="en">
<head>
<style>

/* -- SECTION OPENER -- */
#s-ecosystem .ise-hero {
  display: grid;
  grid-template-columns: 1fr 340px;
  gap: 0;
  border: 1px solid var(--bdr);
  border-radius: var(--r);
  overflow: hidden;
  margin-bottom: 36px;
}
#s-ecosystem .ise-hero-left {
  background: var(--ink);
  padding: 44px 48px;
  position: relative;
  overflow: hidden;
}
#s-ecosystem .ise-hero-left::before {
  content: '';
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse at 0% 0%, rgba(164,16,52,.35) 0%, transparent 55%),
    radial-gradient(ellipse at 100% 100%, rgba(182,134,44,.12) 0%, transparent 50%);
  pointer-events: none;
}
#s-ecosystem .ise-hero-left::after {
  content: '⬡⬡⬡⬡⬡⬡⬡⬡⬡⬡⬡⬡';
  position: absolute; top: -6px; right: -4px;
  font-size: 4.5rem; letter-spacing: 4px; line-height: 1.1;
  color: rgba(255,255,255,.025); pointer-events: none;
  word-break: break-all; width: 160px;
}
#s-ecosystem .ise-hero-eyebrow {
  font-family: var(--mono);
  font-size: .65rem; letter-spacing: .2em;
  text-transform: uppercase; color: var(--gold2);
  margin-bottom: 14px; position: relative;
}
#s-ecosystem .ise-hero-title {
  font-family: var(--display);
  font-size: clamp(1.4rem,3vw,2rem);
  font-weight: 700; color: #fff; line-height: 1.2;
  letter-spacing: -.02em; margin-bottom: 18px;
  position: relative;
}
#s-ecosystem .ise-hero-title em { font-style: italic; color: var(--gold2); }
#s-ecosystem .ise-hero-body {
  font-size: .93rem; color: rgba(255,255,255,.68);
  line-height: 1.78; max-width: 560px;
  position: relative;
}
#s-ecosystem .ise-hero-body strong { color: rgba(255,255,255,.92); }
#s-ecosystem .ise-hero-right {
  background: var(--gold-pale);
  border-left: 1px solid var(--bdr);
  padding: 32px 28px;
  display: flex; flex-direction: column; justify-content: space-between;
}
#s-ecosystem .ise-hero-right-label {
  font-family: var(--mono); font-size: .62rem;
  letter-spacing: .14em; text-transform: uppercase;
  color: var(--gold); margin-bottom: 14px;
}
#s-ecosystem .ise-principle {
  display: flex; gap: 12px; align-items: flex-start;
  margin-bottom: 14px;
}
#s-ecosystem .ise-principle:last-child { margin-bottom: 0; }
#s-ecosystem .ise-p-icon {
  width: 28px; height: 28px; border-radius: 50%;
  background: var(--cr); color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: .75rem; flex-shrink: 0; margin-top: 1px;
}
#s-ecosystem .ise-p-icon.gold { background: var(--gold); }
#s-ecosystem .ise-p-icon.ink  { background: var(--slate); }
#s-ecosystem .ise-p-icon.gn   { background: var(--ok); }
#s-ecosystem .ise-p-title {
  font-family: var(--display); font-size: .9rem;
  font-weight: 700; color: var(--ink); line-height: 1.3;
  margin-bottom: 2px;
}
#s-ecosystem .ise-p-desc {
  font-size: .78rem; color: var(--mid); line-height: 1.55;
}

/* -- CARD GRID (2 cols) -- */
#s-ecosystem .ise-card-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
  margin-bottom: 28px;
}
#s-ecosystem .ise-card-grid .ise-full { grid-column: span 2; }

/* -- CARD BASE CHROME -- */
#s-ecosystem .ise-card {
  background: #fff;
  border: 1px solid var(--bdr);
  border-radius: var(--r);
  overflow: hidden;
}
#s-ecosystem .ise-card-cap {
  padding: 18px 24px 14px;
  border-bottom: 1px solid var(--bdr);
  display: flex; align-items: flex-start; gap: 14px;
}
#s-ecosystem .ise-card-cap.cr  { background: linear-gradient(135deg,var(--cr3),var(--cr2)); }
#s-ecosystem .ise-card-cap.gd  { background: linear-gradient(135deg,#6B4A10,var(--gold)); }
#s-ecosystem .ise-card-cap.ink { background: linear-gradient(135deg,#0E0E0E,var(--slate)); }
#s-ecosystem .ise-card-cap.gn  { background: linear-gradient(135deg,#0F3320,var(--ok)); }
#s-ecosystem .ise-cap-num {
  font-family: var(--display); font-size: 2.2rem; font-weight: 700;
  color: rgba(255,255,255,.18); line-height: 1; flex-shrink: 0;
  margin-top: 2px;
}
#s-ecosystem .ise-cap-label {
  font-family: var(--mono); font-size: .6rem; letter-spacing: .14em;
  text-transform: uppercase; color: rgba(255,255,255,.5); margin-bottom: 4px;
}
#s-ecosystem .ise-cap-title {
  font-family: var(--display); font-size: 1.05rem; font-weight: 700;
  color: #fff; line-height: 1.25;
}
#s-ecosystem .ise-cap-sub {
  font-size: .78rem; color: rgba(255,255,255,.55);
  margin-top: 4px; line-height: 1.5;
}
#s-ecosystem .ise-card-body { padding: 22px 24px; }
#s-ecosystem .ise-card-body p {
  font-size: .9rem; color: var(--mid); line-height: 1.75; margin-bottom: .9em;
}
#s-ecosystem .ise-card-body p:last-child { margin-bottom: 0; }
#s-ecosystem .ise-card-body strong { color: var(--ink); }

/* ==============================================
   CARD 1 – SCHOOL-SPECIFIC DATA CONNECT
   Pipeline flow visualisation
============================================== */
#s-ecosystem .pipe-flow {
  display: flex; gap: 0; margin: 18px 0; flex-wrap: nowrap;
}
@media(max-width:780px) {
  #s-ecosystem .pipe-flow { flex-wrap: wrap; }
}
#s-ecosystem .pipe-node {
  flex: 1; min-width: 88px;
  background: var(--cream); border: 1px solid var(--bdr);
  padding: 14px 10px 12px;
  text-align: center; position: relative;
}
#s-ecosystem .pipe-node::after {
  content: '▶';
  position: absolute; right: -11px; top: 50%;
  transform: translateY(-50%);
  color: var(--cr); font-size: .75rem; z-index: 2;
  background: #fff; padding: 0 2px; line-height: 1;
}
#s-ecosystem .pipe-node:last-child::after { display: none; }
#s-ecosystem .pipe-node.active {
  background: var(--cr); border-color: var(--cr);
}
#s-ecosystem .pipe-node.gold-node {
  background: var(--gold-pale); border-color: var(--gold);
}
#s-ecosystem .pipe-node.green-node {
  background: #EDFAF3; border-color: var(--ok);
}
#s-ecosystem .pipe-icon {
  font-size: 1.3rem; line-height: 1; margin-bottom: 6px;
}
#s-ecosystem .pipe-label {
  font-family: var(--mono); font-size: .58rem; letter-spacing: .08em;
  text-transform: uppercase; color: var(--mid); margin-bottom: 3px;
}
#s-ecosystem .pipe-node.active .pipe-label { color: rgba(255,255,255,.65); }
#s-ecosystem .pipe-title {
  font-family: var(--display); font-size: .82rem; font-weight: 700;
  color: var(--ink); line-height: 1.3;
}
#s-ecosystem .pipe-node.active .pipe-title { color: #fff; }
#s-ecosystem .pipe-node.gold-node .pipe-title { color: #5A3A00; }
#s-ecosystem .pipe-node.green-node .pipe-title { color: #1A4026; }
#s-ecosystem .pipe-sub {
  font-size: .68rem; color: var(--mid); margin-top: 3px; line-height: 1.4;
}
#s-ecosystem .pipe-node.active .pipe-sub { color: rgba(255,255,255,.58); }

/* Value proposition callout strip */
#s-ecosystem .ise-vp-strip {
  background: var(--ink);
  padding: 14px 18px;
  border-radius: var(--r);
  margin: 16px 0 0;
  display: flex; align-items: center; gap: 14px;
  flex-wrap: wrap;
}
#s-ecosystem .ise-vp-strip-label {
  font-family: var(--mono); font-size: .6rem; letter-spacing: .12em;
  text-transform: uppercase; color: var(--gold2); flex-shrink: 0;
}
#s-ecosystem .ise-vp-strip-text {
  font-family: var(--display); font-size: .92rem; font-style: italic;
  color: rgba(255,255,255,.82); line-height: 1.45; flex: 1;
}

/* Data obligation table */
#s-ecosystem .ise-obligation-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  border: 1px solid var(--bdr);
  border-radius: var(--r);
  overflow: hidden;
  margin: 16px 0;
}
#s-ecosystem .ise-ob-col {
  background: var(--report-surface, #ffffff);
  min-width: 0;
}
#s-ecosystem .ise-ob-head {
  padding: 10px 14px;
  font-family: var(--mono); font-size: .62rem; letter-spacing: .1em;
  text-transform: uppercase; font-weight: 600;
  border-bottom: 1px solid var(--bdr);
}
#s-ecosystem .ise-ob-head.cr { background: var(--cr); color: #fff; }
#s-ecosystem .ise-ob-head.gn { background: var(--ok); color: #fff; }
#s-ecosystem .ise-ob-item {
  display: flex; align-items: flex-start; gap: 8px;
  padding: 9px 14px;
  border-bottom: 1px solid var(--light);
  font-size: .82rem; color: var(--mid); line-height: 1.5;
}
#s-ecosystem .ise-ob-item:last-child { border-bottom: none; }
#s-ecosystem .ise-ob-item::before {
  content: ' – '; color: var(--bdr); flex-shrink: 0; margin-top: 1px;
}
#s-ecosystem .ise-ob-col:first-child .ise-ob-item::before { color: var(--cr); }
#s-ecosystem .ise-ob-col:last-child .ise-ob-item::before { color: var(--ok); }


/* ==============================================
   CARD 2 – AI-ACCELERATED PROCESSING
   Split Gift Admin | Prospect Intelligence
============================================== */
#s-ecosystem .ise-ai-split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  margin-bottom: 18px;
  border: 1px solid var(--bdr);
  border-radius: var(--r);
  overflow: hidden;
}
#s-ecosystem .ise-ai-pane { padding: 18px 18px 16px; }
#s-ecosystem .ise-ai-pane:first-child {
  border-right: 1px solid var(--bdr);
  background: #FDFBF8;
}
#s-ecosystem .ise-ai-pane:last-child { background: var(--cream); }
#s-ecosystem .ise-ai-pane-head {
  font-family: var(--mono); font-size: .62rem; letter-spacing: .12em;
  text-transform: uppercase; margin-bottom: 12px; font-weight: 600;
}
#s-ecosystem .ise-ai-pane-head.cr { color: var(--cr); }
#s-ecosystem .ise-ai-pane-head.gd { color: var(--gold); }

/* NLP / ML step rows */
#s-ecosystem .ise-nlp-step {
  display: flex; align-items: flex-start; gap: 10px;
  margin-bottom: 11px;
}
#s-ecosystem .ise-nlp-step:last-child { margin-bottom: 0; }
#s-ecosystem .ise-nlp-dot {
  width: 22px; height: 22px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-family: var(--mono); font-size: .6rem; font-weight: 700;
  flex-shrink: 0; margin-top: 1px;
}
#s-ecosystem .ise-nlp-dot.cr { background: #FAE8EB; color: var(--cr); border: 1px solid #E8B4BC; }
#s-ecosystem .ise-nlp-dot.gd { background: var(--gold-pale); color: #7A5A00; border: 1px solid #E0C070; }
#s-ecosystem .ise-nlp-label {
  font-family: var(--display); font-size: .85rem; font-weight: 700;
  color: var(--slate); margin-bottom: 2px; line-height: 1.2;
}
#s-ecosystem .ise-nlp-desc {
  font-size: .78rem;
  color: var(--report-muted, #64748b);
  line-height: 1.5;
  margin: 0;
}

/* Velocity metric */
#s-ecosystem .ise-velocity {
  display: flex; gap: 10px;
  background: var(--ink); border-radius: var(--r);
  padding: 14px 16px; margin-top: 16px;
  align-items: center; flex-wrap: wrap;
}
#s-ecosystem .ise-vel-badge {
  font-family: var(--display); font-size: 2.2rem; font-weight: 700;
  color: var(--gold2); line-height: 1; flex-shrink: 0;
}
#s-ecosystem .ise-vel-sep {
  width: 1px; background: rgba(255,255,255,.1);
  align-self: stretch; margin: 0 4px;
}
#s-ecosystem .ise-vel-label {
  font-family: var(--mono); font-size: .6rem; letter-spacing: .1em;
  text-transform: uppercase; color: rgba(255,255,255,.4); margin-bottom: 3px;
}
#s-ecosystem .ise-vel-text {
  font-size: .85rem; color: rgba(255,255,255,.75); line-height: 1.5;
}
#s-ecosystem .ise-vel-text strong { color: #fff; }

/* Shadow capacity meter */
#s-ecosystem .ise-shadow-cap {
  background: var(--cream); border: 1px solid var(--bdr);
  border-radius: var(--r); padding: 14px 16px; margin-top: 12px;
}
#s-ecosystem .ise-sc-label {
  font-family: var(--mono); font-size: .62rem; letter-spacing: .1em;
  text-transform: uppercase; color: var(--gold); margin-bottom: 10px;
}
#s-ecosystem .ise-sc-row {
  display: flex; align-items: center; gap: 10px; margin-bottom: 8px;
}
#s-ecosystem .ise-sc-row:last-child { margin-bottom: 0; }
#s-ecosystem .ise-sc-name {
  font-size: .78rem; color: var(--slate); font-weight: 600; min-width: 130px;
}
#s-ecosystem .ise-sc-bar-bg {
  flex: 1; height: 7px; background: var(--light);
  border-radius: 3px; overflow: hidden;
}
#s-ecosystem .ise-sc-bar-fill {
  height: 100%; border-radius: 3px;
  transition: width 1.4s ease;
}
#s-ecosystem .ise-sc-val {
  font-family: var(--mono); font-size: .68rem;
  font-weight: 600; min-width: 44px; text-align: right;
}


/* ==============================================
   CARD 3 – ACADEMIC-DONOR NEXUS
   Three-node connection map + Emeritus bar
============================================== */
#s-ecosystem .ise-nexus-map {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  gap: 0;
  align-items: stretch;
  margin: 18px 0;
  border: 1px solid var(--bdr);
  border-radius: var(--r);
  overflow: hidden;
}
#s-ecosystem .ise-nexus-node {
  padding: 18px 16px; text-align: center;
}
#s-ecosystem .ise-nexus-node.research {
  background: var(--cream); border-right: 1px solid var(--bdr);
}
#s-ecosystem .ise-nexus-node.matching {
  background: var(--cr); min-width: 110px;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  padding: 18px 14px;
}
#s-ecosystem .ise-nexus-node.donor {
  background: var(--gold-pale); border-left: 1px solid var(--bdr);
}
#s-ecosystem .ise-nexus-icon {
  font-size: 1.8rem; line-height: 1; margin-bottom: 8px;
}
#s-ecosystem .ise-nexus-label {
  font-family: var(--mono); font-size: .58rem; letter-spacing: .1em;
  text-transform: uppercase; margin-bottom: 5px;
}
#s-ecosystem .ise-nexus-node.research .ise-nexus-label { color: var(--mid); }
#s-ecosystem .ise-nexus-node.matching .ise-nexus-label { color: rgba(255,255,255,.55); }
#s-ecosystem .ise-nexus-node.donor .ise-nexus-label { color: var(--gold); }
#s-ecosystem .ise-nexus-title {
  font-family: var(--display); font-size: .95rem;
  font-weight: 700; line-height: 1.25; margin-bottom: 8px;
}
#s-ecosystem .ise-nexus-node.research .ise-nexus-title { color: var(--ink); }
#s-ecosystem .ise-nexus-node.matching .ise-nexus-title { color: #fff; font-size: .88rem; }
#s-ecosystem .ise-nexus-node.donor .ise-nexus-title { color: var(--ink); }
#s-ecosystem .ise-nexus-chip {
  display: inline-block; padding: 3px 8px;
  border-radius: 2px; font-family: var(--mono);
  font-size: .6rem; letter-spacing: .04em;
  margin: 2px 2px 0 0;
}
#s-ecosystem .ise-nexus-node.research .ise-nexus-chip {
  background: #fff; color: var(--mid); border: 1px solid var(--bdr);
}
#s-ecosystem .ise-nexus-node.matching .ise-nexus-chip {
  background: rgba(255,255,255,.12); color: rgba(255,255,255,.8);
  border: 1px solid rgba(255,255,255,.15);
}
#s-ecosystem .ise-nexus-node.donor .ise-nexus-chip {
  background: #fff; color: #7A5A00; border: 1px solid #E0C070;
}
#s-ecosystem .ise-nexus-arrow {
  display: flex; align-items: center; justify-content: center;
  color: rgba(255,255,255,.55); font-size: .8rem; padding: 0 2px;
}

/* Emeritus bar */
#s-ecosystem .ise-emeritus-bar {
  background: var(--ink);
  border-radius: var(--r);
  padding: 16px 20px;
  margin-top: 14px;
  display: flex; align-items: flex-start; gap: 16px;
  flex-wrap: wrap;
}
#s-ecosystem .ise-em-icon {
  font-size: 1.8rem; flex-shrink: 0;
}
#s-ecosystem .ise-em-label {
  font-family: var(--mono); font-size: .6rem; letter-spacing: .12em;
  text-transform: uppercase; color: var(--gold2); margin-bottom: 4px;
}
#s-ecosystem .ise-em-title {
  font-family: var(--display); font-size: 1rem; font-weight: 700;
  color: #fff; margin-bottom: 5px;
}
#s-ecosystem .ise-em-body {
  font-size: .82rem; color: rgba(255,255,255,.65); line-height: 1.65;
  flex: 1; min-width: 200px;
}
#s-ecosystem .ise-em-body strong { color: rgba(255,255,255,.9); }
#s-ecosystem .ise-stanford-cite {
  font-family: var(--mono); font-size: .65rem; color: var(--gold2);
  letter-spacing: .05em; margin-top: 8px; display: block;
}


/* ==============================================
   CARD 4 – THE IDEAS PORTAL (Innovation Drop Box)
   Full-width; portal UI mockup
============================================== */
#s-ecosystem .ise-portal-wrap {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
}
#s-ecosystem .ise-portal-left {
  padding: 22px 24px;
  border-right: 1px solid var(--bdr);
}
#s-ecosystem .ise-portal-right {
  padding: 22px 24px;
  background: var(--cream);
}

/* Submission interface mockup */
#s-ecosystem .ise-submit-box {
  background: #fff;
  border: 1px solid var(--bdr);
  border-radius: var(--r);
  overflow: hidden;
  margin-bottom: 14px;
  box-shadow: var(--shadow);
}
#s-ecosystem .ise-submit-bar {
  background: var(--cr);
  padding: 8px 14px;
  display: flex; align-items: center; justify-content: space-between;
}
#s-ecosystem .ise-submit-bar-title {
  font-family: var(--mono); font-size: .65rem; letter-spacing: .1em;
  text-transform: uppercase; color: rgba(255,255,255,.85);
}
#s-ecosystem .ise-submit-dot {
  width: 7px; height: 7px; border-radius: 50%;
  background: var(--gold2); display: inline-block; margin-left: 4px;
}
#s-ecosystem .ise-submit-dot.amber { background: #F5A623; }
#s-ecosystem .ise-submit-dot.grey  { background: rgba(255,255,255,.3); }
#s-ecosystem .ise-submit-body { padding: 14px; }
#s-ecosystem .ise-submit-field {
  background: var(--cream); border: 1px solid var(--bdr);
  border-radius: 2px; padding: 8px 12px; margin-bottom: 8px;
  font-size: .78rem; color: var(--mid);
  font-family: var(--serif);
}
#s-ecosystem .ise-submit-field.placeholder { color: var(--bdr); font-style: italic; }
#s-ecosystem .ise-submit-tags {
  display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 10px;
}
#s-ecosystem .ise-submit-tag {
  padding: 4px 10px; border-radius: 20px; cursor: pointer;
  font-family: var(--mono); font-size: .62rem; letter-spacing: .04em;
  border: 1px solid;
}
#s-ecosystem .ise-submit-tag.sel {
  background: var(--cr); color: #fff; border-color: var(--cr);
}
#s-ecosystem .ise-submit-tag.unsel {
  background: #fff; color: var(--mid); border-color: var(--bdr);
}
#s-ecosystem .ise-submit-btn {
  background: var(--cr); color: #fff; border: none;
  padding: 8px 18px; border-radius: 2px; width: 100%;
  font-family: var(--display); font-size: .88rem; font-weight: 600;
  cursor: pointer; letter-spacing: .01em;
}

/* Incubation pipeline stages */
#s-ecosystem .ise-incubator {
  display: flex; gap: 0; flex-direction: column;
}
#s-ecosystem .ise-stage {
  display: flex; align-items: stretch; gap: 0; margin-bottom: 10px;
}
#s-ecosystem .ise-stage:last-child { margin-bottom: 0; }
#s-ecosystem .ise-stage-badge {
  min-width: 120px; padding: 10px 12px;
  font-family: var(--mono); font-size: .62rem; letter-spacing: .08em;
  text-transform: uppercase; font-weight: 700;
  display: flex; align-items: center; border-radius: var(--r) 0 0 var(--r);
  flex-shrink: 0;
}
#s-ecosystem .ise-stage.s1 .ise-stage-badge { background: var(--light); color: var(--mid); }
#s-ecosystem .ise-stage.s2 .ise-stage-badge { background: #FDF6E3; color: #7A5A00; }
#s-ecosystem .ise-stage.s3 .ise-stage-badge { background: #FAE8EB; color: var(--cr); }
#s-ecosystem .ise-stage.s4 .ise-stage-badge { background: #E6F4ED; color: #1A5C33; }
#s-ecosystem .ise-stage-content {
  flex: 1; background: #fff; border: 1px solid var(--bdr);
  border-left: none; border-radius: 0 var(--r) var(--r) 0;
  padding: 10px 14px;
}
#s-ecosystem .ise-stage-title {
  font-family: var(--display); font-size: .88rem; font-weight: 700;
  color: var(--ink); margin-bottom: 3px;
}
#s-ecosystem .ise-stage-desc {
