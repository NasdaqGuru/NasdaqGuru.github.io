<script id="harvard-inline-index-final-script">
(function(){
  function ready(fn){document.readyState==='loading'?document.addEventListener('DOMContentLoaded',fn):fn();}
  function apply(){
    document.body.classList.remove('uaad-theme-blueprint','uaad-theme-adoptive','theme-clean-exec','clean-executive-report');
    document.body.classList.add('harvard-inline-index');

    var sidebar=document.getElementById('sidebar');
    var layout=document.querySelector('.layout');
    var main=document.getElementById('mainContent')||document.querySelector('.main-content');
    if(sidebar && layout && sidebar.parentElement!==layout){layout.insertBefore(sidebar, layout.firstChild);} 
    if(sidebar){
      ['position','left','right','bottom','width','minWidth','marginLeft','transform'].forEach(function(k){sidebar.style[k]='';});
      sidebar.style.position='sticky'; sidebar.style.top='0'; sidebar.style.height='100vh'; sidebar.style.zIndex='4';
    }
    if(main){main.style.marginLeft='0';main.style.width='100%';main.style.maxWidth='100%';}
    document.querySelectorAll('.hks-exec-masthead,.masthead,.report-masthead-v3,.site-header,.page-header,.site-footer,footer').forEach(function(el){el.style.marginLeft='0';el.style.width='100%';el.style.maxWidth='100%';});
    document.querySelectorAll('.report-utility-dock').forEach(function(el){el.style.display='none';});

    // Make sure Keyword Search is available in the masthead, not as a floating overlay.
    var actions=document.querySelector('.mast-v3-actions');
