      var b=document.createElement('button');
      b.type='button'; b.className='mast-v3-button report-search-trigger'; b.textContent='Keyword Search';
      b.onclick=function(){ if(window.openReportSearchPatch) window.openReportSearchPatch(); };
      actions.insertBefore(b, actions.firstChild);
    }

    // Stop older cleanup scripts from turning the masthead text black via inline styles.
    document.querySelectorAll('.report-masthead-v3 *,.masthead *,.site-header *,.page-header *').forEach(function(el){
      if(!el.matches('button,.mast-v3-button,.mast-action-tab')){el.style.color=''; el.style.textShadow='none';}
    });
  }
  ready(function(){apply(); setTimeout(apply,250); setTimeout(apply,1000);});
})();
